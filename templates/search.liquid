{% layout 'theme' %}
<div class="page-width" style="padding: var(--section-pad) 20px; max-width:var(--container); margin:0 auto;">
  <h1 style="font-family:var(--font-display);font-size:clamp(1.8rem,4vw,2.8rem);font-weight:300;margin-bottom:1.5rem;">Search</h1>
  <form action="{{ routes.search_url }}" method="get" role="search" style="margin-bottom:2rem;">
    <input type="hidden" name="type" value="product">
    <div style="display:flex;gap:8px;">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products…"
        style="flex:1;padding:12px 16px;border:1px solid var(--light-gray);border-radius:4px;font-size:1rem;font-family:var(--font-body);"
        aria-label="Search" autofocus>
      <button type="submit" class="btn-primary">Search</button>
    </div>
  </form>
  {%- if search.performed -%}
    {%- if search.results_count == 0 -%}
      <p style="color:var(--mid-gray);">No results for <strong>{{ search.terms | escape }}</strong>. Try a different search term.</p>
    {%- else -%}
      <p style="color:var(--mid-gray);margin-bottom:1.5rem;">{{ search.results_count }} result{{ search.results_count | plural: '', 's' }} for <strong>{{ search.terms | escape }}</strong></p>
      <div class="col-grid col-grid--3col">
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            <article class="coll-pc">
              <div class="coll-pc-img-area">
                <a href="{{ item.url }}" class="coll-pc-img-link">
                  <div class="coll-pc-img-wrap">
                    {%- if item.featured_image -%}
                      <img src="{{ item.featured_image | image_url: width: 540, height: 540, crop: 'center' }}" alt="{{ item.featured_image.alt | default: item.title | escape }}" class="coll-pc-img coll-pc-img--a" loading="lazy" width="540" height="540">
                    {%- endif -%}
                  </div>
                </a>
              </div>
              <div class="coll-pc-info">
                <h3 class="coll-pc-title"><a href="{{ item.url }}">{{ item.title }}</a></h3>
                <div class="coll-pc-price-row">
                  <span class="coll-pc-price">{{ item.price | money }}</span>
                </div>
              </div>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  {%- endif -%}
</div>
