{% layout 'theme' %}
<div style="min-height:60vh;display:flex;align-items:center;justify-content:center;padding:var(--section-pad) 20px;">
  <div style="width:100%;max-width:420px;">
    <h1 style="font-family:var(--font-display);font-size:2rem;font-weight:300;text-align:center;margin-bottom:2rem;">Sign In</h1>

    {%- form 'customer_login' -%}
      {%- if form.errors -%}
        <div style="background:#fef2f2;border:1px solid #fca5a5;border-radius:4px;padding:12px 16px;margin-bottom:1rem;font-size:.9rem;color:#991b1b;">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div style="margin-bottom:1rem;">
        <label for="CustomerEmail" style="display:block;font-size:.85rem;margin-bottom:6px;color:var(--mid-gray);">Email</label>
        <input type="email" name="customer[email]" id="CustomerEmail" autocomplete="email" autocapitalize="off"
          style="width:100%;padding:12px 14px;border:1px solid var(--light-gray);border-radius:4px;font-size:1rem;box-sizing:border-box;" required>
      </div>
      <div style="margin-bottom:1.5rem;">
        <div style="display:flex;justify-content:space-between;margin-bottom:6px;">
          <label for="CustomerPassword" style="font-size:.85rem;color:var(--mid-gray);">Password</label>
          <a href="{{ routes.account_recover_url }}" style="font-size:.8rem;color:var(--navy);">Forgot password?</a>
        </div>
        <input type="password" name="customer[password]" id="CustomerPassword" autocomplete="current-password"
          style="width:100%;padding:12px 14px;border:1px solid var(--light-gray);border-radius:4px;font-size:1rem;box-sizing:border-box;" required>
      </div>
      <button type="submit" class="btn-primary btn-full" style="width:100%;">Sign In</button>
    {%- endform -%}

    <p style="text-align:center;margin-top:1.5rem;font-size:.9rem;color:var(--mid-gray);">
      Don't have an account? <a href="{{ routes.account_register_url }}" style="color:var(--navy);">Create one</a>
    </p>
  </div>
</div>
