{% doc %}
  @prompt
    Create a comprehensive contact page section that matches the existing theme style. The section should include: a contact form (with name, email, message fields and submit button), social media links (icons for Instagram, Facebook, Twitter, LinkedIn, etc.), business address, phone number, email address, and an embedded Google Map. The design should be clean, professional, and visually consistent with the theme's colors, fonts, and overall aesthetic. Layout should be well-organized with the contact form on one side and the contact details (address, phone, email, social media, map) on the other side.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 20px;
  }

  .ai-contact-container-{{ ai_gen_id }} {
    max-width: 1320px;
    margin: 0 auto;
  }

  .ai-contact-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 60px;
  }

  .ai-contact-title-{{ ai_gen_id }} {
    font-family: 'Cormorant Garamond', serif;
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 300;
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px 0;
    line-height: 1.2;
  }

  .ai-contact-subtitle-{{ ai_gen_id }} {
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    color: {{ block.settings.text_color }};
    margin: 0;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-contact-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }

  .ai-contact-form-wrapper-{{ ai_gen_id }} {
    background-color: {{ block.settings.form_background }};
    padding: 40px;
    border-radius: 2px;
  }

  .ai-contact-form-title-{{ ai_gen_id }} {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 300;
    color: {{ block.settings.heading_color }};
    margin: 0 0 24px 0;
  }

  .ai-contact-form-field-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .ai-contact-form-label-{{ ai_gen_id }} {
    display: block;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: {{ block.settings.text_color }};
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-contact-form-input-{{ ai_gen_id }},
  .ai-contact-form-textarea-{{ ai_gen_id }} {
    width: 100%;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    color: {{ block.settings.text_color }};
    background-color: transparent;
    border: none;
    border-bottom: 1px solid {{ block.settings.input_border_color }};
    padding: 12px 0;
    transition: border-color 0.3s ease;
  }

  .ai-contact-form-input-{{ ai_gen_id }}:focus,
  .ai-contact-form-textarea-{{ ai_gen_id }}:focus {
    outline: none;
    border-bottom-color: {{ block.settings.input_focus_color }};
  }

  .ai-contact-form-textarea-{{ ai_gen_id }} {
    resize: vertical;
    min-height: 120px;
  }

  .ai-contact-form-button-{{ ai_gen_id }} {
    width: 100%;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: {{ block.settings.button_text_color }};
    background-color: {{ block.settings.button_bg_color }};
    border: none;
    padding: 16px 32px;
    cursor: pointer;
    transition: background-color 0.3s ease;
    border-radius: 0;
  }

  .ai-contact-form-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-contact-form-success-{{ ai_gen_id }} {
    color: #008060;
    font-size: 14px;
    margin-top: 12px;
  }

  .ai-contact-form-error-{{ ai_gen_id }} {
    color: #D82C0D;
    font-size: 14px;
    margin-top: 12px;
  }

  .ai-contact-info-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .ai-contact-info-block-{{ ai_gen_id }} {
    padding-bottom: 32px;
    border-bottom: 1px solid {{ block.settings.divider_color }};
  }

  .ai-contact-info-block-{{ ai_gen_id }}:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .ai-contact-info-heading-{{ ai_gen_id }} {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 300;
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px 0;
  }

  .ai-contact-info-text-{{ ai_gen_id }} {
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0 0 8px 0;
  }

  .ai-contact-info-link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .ai-contact-info-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-contact-social-icons-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    margin-top: 12px;
  }

  .ai-contact-social-link-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: {{ block.settings.social_bg_color }};
    color: {{ block.settings.social_icon_color }};
    border-radius: 50%;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .ai-contact-social-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.social_hover_bg }};
    color: {{ block.settings.social_hover_icon }};
    transform: translateY(-2px);
  }

  .ai-contact-social-link-{{ ai_gen_id }} svg {
    width: 18px;
    height: 18px;
  }

  .ai-contact-map-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: 300px;
    background-color: #f4f4f4;
    border-radius: 2px;
    overflow: hidden;
  }

  .ai-contact-map-wrapper-{{ ai_gen_id }} iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  .ai-contact-map-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #F5F0E8;
    color: #888780;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    text-align: center;
    padding: 20px;
  }

  @media screen and (max-width: 989px) {
    .ai-contact-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .ai-contact-form-wrapper-{{ ai_gen_id }} {
      padding: 30px;
    }

    .ai-contact-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-contact-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.6 }}px 16px;
    }

    .ai-contact-header-{{ ai_gen_id }} {
      margin-bottom: 40px;
    }

    .ai-contact-form-wrapper-{{ ai_gen_id }} {
      padding: 24px;
    }

    .ai-contact-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }

    .ai-contact-form-title-{{ ai_gen_id }} {
      font-size: 24px;
    }

    .ai-contact-info-heading-{{ ai_gen_id }} {
      font-size: 20px;
    }
  }
{% endstyle %}

<contact-section-{{ ai_gen_id }} class="ai-contact-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-container-{{ ai_gen_id }}">
    {% if block.settings.show_header %}
      <div class="ai-contact-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h1 class="ai-contact-title-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <p class="ai-contact-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-contact-grid-{{ ai_gen_id }}">
      <div class="ai-contact-form-wrapper-{{ ai_gen_id }}">
        {% if block.settings.form_title != blank %}
          <h2 class="ai-contact-form-title-{{ ai_gen_id }}">{{ block.settings.form_title }}</h2>
        {% endif %}

        {% form 'contact' %}
          {% if form.posted_successfully? %}
            <div class="ai-contact-form-success-{{ ai_gen_id }}" id="ai-contact-success-{{ ai_gen_id }}">
              {{ block.settings.success_message }}
            </div>
          {% endif %}

          {% if form.errors %}
            <div class="ai-contact-form-error-{{ ai_gen_id }}" id="ai-contact-error-{{ ai_gen_id }}">
              {{ form.errors.messages.email }}
            </div>
          {% endif %}

          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label for="ai-contact-name-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">
              Name
            </label>
            <input
              type="text"
              id="ai-contact-name-{{ ai_gen_id }}"
              name="contact[name]"
              class="ai-contact-form-input-{{ ai_gen_id }}"
              required
              {% if form.posted_successfully? %}
                aria-describedby="ai-contact-success-{{ ai_gen_id }}"
              {% endif %}
            >
          </div>

          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label for="ai-contact-email-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">
              Email
            </label>
            <input
              type="email"
              id="ai-contact-email-{{ ai_gen_id }}"
              name="contact[email]"
              class="ai-contact-form-input-{{ ai_gen_id }}"
              autocomplete="email"
              autocorrect="off"
              autocapitalize="off"
              required
              {% if form.errors %}
                aria-invalid="true"
                aria-describedby="ai-contact-error-{{ ai_gen_id }}"
              {% endif %}
              {% if form.posted_successfully? %}
                aria-describedby="ai-contact-success-{{ ai_gen_id }}"
              {% endif %}
            >
          </div>

          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label for="ai-contact-phone-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">
              Phone (Optional)
            </label>
            <input
              type="tel"
              id="ai-contact-phone-{{ ai_gen_id }}"
              name="contact[phone]"
              class="ai-contact-form-input-{{ ai_gen_id }}"
              autocomplete="tel"
            >
          </div>

          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label for="ai-contact-message-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">
              Message
            </label>
            <textarea
              id="ai-contact-message-{{ ai_gen_id }}"
              name="contact[body]"
              class="ai-contact-form-textarea-{{ ai_gen_id }}"
              required
              {% if form.posted_successfully? %}
                aria-describedby="ai-contact-success-{{ ai_gen_id }}"
              {% endif %}
            ></textarea>
          </div>

          <button type="submit" class="ai-contact-form-button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </button>
        {% endform %}
      </div>

      <div class="ai-contact-info-wrapper-{{ ai_gen_id }}">
        {% if block.settings.show_address and block.settings.address != blank %}
          <div class="ai-contact-info-block-{{ ai_gen_id }}">
            <h3 class="ai-contact-info-heading-{{ ai_gen_id }}">{{ block.settings.address_heading }}</h3>
            <div class="ai-contact-info-text-{{ ai_gen_id }}">
              {{ block.settings.address | newline_to_br }}
            </div>
          </div>
        {% endif %}

        {% if block.settings.show_contact_details %}
          <div class="ai-contact-info-block-{{ ai_gen_id }}">
            <h3 class="ai-contact-info-heading-{{ ai_gen_id }}">{{ block.settings.contact_heading }}</h3>
            {% if block.settings.phone != blank %}
              <p class="ai-contact-info-text-{{ ai_gen_id }}">
                <a href="tel:{{ block.settings.phone }}" class="ai-contact-info-link-{{ ai_gen_id }}">
                  {{ block.settings.phone }}
                </a>
              </p>
            {% endif %}
            {% if block.settings.email != blank %}
              <p class="ai-contact-info-text-{{ ai_gen_id }}">
                <a href="mailto:{{ block.settings.email }}" class="ai-contact-info-link-{{ ai_gen_id }}">
                  {{ block.settings.email }}
                </a>
              </p>
            {% endif %}
          </div>
        {% endif %}

        {% if block.settings.show_social %}
          <div class="ai-contact-info-block-{{ ai_gen_id }}">
            <h3 class="ai-contact-info-heading-{{ ai_gen_id }}">{{ block.settings.social_heading }}</h3>
            <div class="ai-contact-social-icons-{{ ai_gen_id }}">
              {% if block.settings.instagram_url != blank %}
                <a href="{{ block.settings.instagram_url }}" class="ai-contact-social-link-{{ ai_gen_id }}" target="_blank" rel="noopener" aria-label="Instagram">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                    <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                  </svg>
                </a>
              {% endif %}

              {% if block.settings.facebook_url != blank %}
                <a href="{{ block.settings.facebook_url }}" class="ai-contact-social-link-{{ ai_gen_id }}" target="_blank" rel="noopener" aria-label="Facebook">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
                  </svg>
                </a>
              {% endif %}

              {% if block.settings.twitter_url != blank %}
                <a href="{{ block.settings.twitter_url }}" class="ai-contact-social-link-{{ ai_gen_id }}" target="_blank" rel="noopener" aria-label="Twitter">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path>
                  </svg>
                </a>
              {% endif %}

              {% if block.settings.linkedin_url != blank %}
                <a href="{{ block.settings.linkedin_url }}" class="ai-contact-social-link-{{ ai_gen_id }}" target="_blank" rel="noopener" aria-label="LinkedIn">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                    <rect x="2" y="9" width="4" height="12"></rect>
                    <circle cx="4" cy="4" r="2"></circle>
                  </svg>
                </a>
              {% endif %}

              {% if block.settings.youtube_url != blank %}
                <a href="{{ block.settings.youtube_url }}" class="ai-contact-social-link-{{ ai_gen_id }}" target="_blank" rel="noopener" aria-label="YouTube">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path>
                    <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon>
                  </svg>
                </a>
              {% endif %}

              {% if block.settings.pinterest_url != blank %}
                <a href="{{ block.settings.pinterest_url }}" class="ai-contact-social-link-{{ ai_gen_id }}" target="_blank" rel="noopener" aria-label="Pinterest">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <path d="M8.5 14.5c.5 2 1.5 3.5 3 3.5 2.5 0 3.5-4 3.5-6.5 0-2-1-3.5-3-3.5s-3.5 1.5-3.5 3.5c0 1.5.5 2.5 1.5 2.5 1 0 1.5-1 1.5-2"></path>
                  </svg>
                </a>
              {% endif %}
            </div>
          </div>
        {% endif %}

        {% if block.settings.show_map %}
          <div class="ai-contact-info-block-{{ ai_gen_id }}">
            <h3 class="ai-contact-info-heading-{{ ai_gen_id }}">{{ block.settings.map_heading }}</h3>
            <div class="ai-contact-map-wrapper-{{ ai_gen_id }}">
              {% if block.settings.map_embed_url != blank %}
                <iframe
                  src="{{ block.settings.map_embed_url }}"
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title="Location map"
                ></iframe>
              {% else %}
                <div class="ai-contact-map-placeholder-{{ ai_gen_id }}">
                  Add your Google Maps embed URL in the block settings
                </div>
              {% endif %}
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</contact-section-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const form = this.querySelector('form');
        if (form) {
          form.addEventListener('submit', function() {
            const button = form.querySelector('.ai-contact-form-button-{{ ai_gen_id }}');
            if (button) {
              button.textContent = 'Sending...';
              button.disabled = true;
            }
          });
        }
      }
    }

    customElements.define('contact-section-{{ ai_gen_id }}', ContactSection{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Contact page",
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "checkbox",
      "id": "show_header",
      "label": "Show section header",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Get in Touch"
    },
    {
      "type": "inline_richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "We'd love to hear from you. Send us a message and we'll respond as soon as possible."
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "header",
      "content": "Contact form"
    },
    {
      "type": "inline_richtext",
      "id": "form_title",
      "label": "Form title",
      "default": "Send us a message"
    },
    {
      "type": "inline_richtext",
      "id": "button_text",
      "label": "Button text",
      "default": "Send Message"
    },
    {
      "type": "inline_richtext",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you! We'll get back to you soon."
    },
    {
      "type": "header",
      "content": "Business address"
    },
    {
      "type": "checkbox",
      "id": "show_address",
      "label": "Show address",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "address_heading",
      "label": "Address heading",
      "default": "Visit Us"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Address",
      "default": "123 Main Street\nNew Delhi, DL 110001\nIndia"
    },
    {
      "type": "header",
      "content": "Contact details"
    },
    {
      "type": "checkbox",
      "id": "show_contact_details",
      "label": "Show contact details",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "contact_heading",
      "label": "Contact heading",
      "default": "Contact Us"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "default": "+91 98765 43210"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address",
      "default": "hello@relicainnovations.com"
    },
    {
      "type": "header",
      "content": "Social media"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social media",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "social_heading",
      "label": "Social heading",
      "default": "Follow Us"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "twitter_url",
      "label": "Twitter URL"
    },
    {
      "type": "url",
      "id": "linkedin_url",
      "label": "LinkedIn URL"
    },
    {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube URL"
    },
    {
      "type": "url",
      "id": "pinterest_url",
      "label": "Pinterest URL"
    },
    {
      "type": "header",
      "content": "Google Map"
    },
    {
      "type": "checkbox",
      "id": "show_map",
      "label": "Show map",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "map_heading",
      "label": "Map heading",
      "default": "Find Us"
    },
    {
      "type": "text",
      "id": "map_embed_url",
      "label": "Google Maps embed URL",
      "info": "Get embed URL from Google Maps > Share > Embed a map"
