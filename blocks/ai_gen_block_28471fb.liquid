{% doc %}
  @prompt
    Create an "Our Story" section for an About Us page with the following content:
    
    Eyebrow label: "Our Story"
    Heading: "Inspired by Tradition, Built for Modern Lifestyles"
    
    Four paragraphs of body text:
    1. "Relica was founded with a simple vision — to create cookware and kitchen solutions that bring together innovation, quality, and everyday practicality. Inspired by the evolving needs of modern kitchens, we set out to design products that simplify cooking while maintaining premium quality and elegant design."
    2. "Cooking has always been an important part of every home — a place where families connect, traditions continue, and memories are created. Understanding this emotional connection, we focused on building products that not only perform exceptionally but also make every cooking experience more enjoyable and effortless."
    3. "Over the years, Relica has expanded its product range with thoughtfully engineered cookware and appliances crafted using high-quality materials and advanced technology. Whether it's preparing daily meals or experimenting with new recipes, our products are designed to support every culinary journey with reliability and ease."
    4. "Today, Relica proudly serves modern households with products that reflect trust, durability, innovation, and a passion for better cooking experiences."
    
    Design requirements:
    - Match the existing theme's fonts, colors, and typography styles
    - Clean, professional layout with generous whitespace
    - Eyebrow text "Our Story" above the main heading in a smaller styled label
    - Heading should be prominent and elegant
    - Body text readable with good line spacing
    - Subtle decorative divider or accent element
    - Fully responsive for mobile and desktop
    - All text fields editable in the theme editor
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-our-story-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-our-story-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-our-story-eyebrow-{{ ai_gen_id }} {
    display: inline-block;
    font-family: {{ block.settings.body_font }}, sans-serif;
    font-size: {{ block.settings.eyebrow_size }}px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: {{ block.settings.eyebrow_color }};
    margin-bottom: {{ block.settings.eyebrow_spacing }}px;
  }

  .ai-our-story-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font }}, serif;
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    line-height: 1.2;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
  }

  .ai-our-story-divider-{{ ai_gen_id }} {
    width: {{ block.settings.divider_width }}px;
    height: {{ block.settings.divider_height }}px;
    background-color: {{ block.settings.divider_color }};
    margin: 0 auto {{ block.settings.divider_spacing }}px;
    border-radius: {{ block.settings.divider_height | divided_by: 2 }}px;
  }

  .ai-our-story-body-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font }}, sans-serif;
    font-size: {{ block.settings.body_size }}px;
    line-height: {{ block.settings.body_line_height }};
    color: {{ block.settings.body_color }};
  }

  .ai-our-story-body-{{ ai_gen_id }} p {
    margin: 0 0 {{ block.settings.paragraph_spacing }}px;
  }

  .ai-our-story-body-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 768px) {
    .ai-our-story-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.6 }}px 16px {{ block.settings.section_padding_bottom | times: 0.6 }}px;
    }

    .ai-our-story-eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.eyebrow_size | times: 0.9 }}px;
    }

    .ai-our-story-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.65 }}px;
    }

    .ai-our-story-body-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size | times: 0.95 }}px;
    }
  }
{% endstyle %}

<div class="ai-our-story-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-our-story-container-{{ ai_gen_id }}">
    {% if block.settings.eyebrow_text != blank %}
      <div class="ai-our-story-eyebrow-{{ ai_gen_id }}">
        {{ block.settings.eyebrow_text }}
      </div>
    {% endif %}

    {% if block.settings.heading != blank %}
      <h2 class="ai-our-story-heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.show_divider %}
      <div class="ai-our-story-divider-{{ ai_gen_id }}"></div>
    {% endif %}

    <div class="ai-our-story-body-{{ ai_gen_id }}">
      {% if block.settings.paragraph_1 != blank %}
        <p>{{ block.settings.paragraph_1 }}</p>
      {% endif %}

      {% if block.settings.paragraph_2 != blank %}
        <p>{{ block.settings.paragraph_2 }}</p>
      {% endif %}

      {% if block.settings.paragraph_3 != blank %}
        <p>{{ block.settings.paragraph_3 }}</p>
      {% endif %}

      {% if block.settings.paragraph_4 != blank %}
        <p>{{ block.settings.paragraph_4 }}</p>
      {% endif %}
    </div>
  </div>
</div>

