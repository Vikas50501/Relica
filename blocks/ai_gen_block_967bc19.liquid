{% doc %}
  @prompt
    Create an "About Relica" section for the About Us page with the following content:
    
    Heading: "Crafted for Modern Kitchens, Designed for Everyday Living"
    
    Body text: "At Relica, we believe that every kitchen deserves products that combine performance, durability, and elegance. As a modern cookware and kitchen appliances brand, our mission is to transform everyday cooking into a seamless and enjoyable experience.
    
    We design products that perfectly blend innovation with functionality, helping families cook with comfort, confidence, and convenience. From premium cookware collections to advanced kitchen appliances, every Relica product is thoughtfully crafted to meet the needs of modern households.
    
    Our focus goes beyond just manufacturing kitchen products — we aim to create reliable solutions that make cooking faster, healthier, and more efficient while adding a touch of sophistication to every kitchen space.
    
    With a commitment to quality craftsmanship, modern aesthetics, and long-lasting durability, Relica continues to become a trusted companion for homes that value both style and performance."
    
    Design requirements:
    - Match the existing theme's fonts, colors, and typography
    - Clean, professional, and elegant layout
    - Section should have editable fields for heading and body text in the theme editor
    - Optionally include a subtle background color or divider to distinguish the section
    - Responsive design for mobile and desktop
    - Consider adding an optional image field (e.g., kitchen/cookware lifestyle photo) alongside the text for visual appeal
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-about-relica-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_desktop }}px 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-about-relica-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_mobile }}px 16px;
    }
  }

  .ai-about-relica-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.content_gap }}px;
    align-items: center;
  }

  @media screen and (min-width: 750px) {
    .ai-about-relica-container-{{ ai_gen_id }} {
      grid-template-columns: {% if block.settings.layout == 'image_left' %}1fr 1.2fr{% elsif block.settings.layout == 'image_right' %}1.2fr 1fr{% else %}1fr{% endif %};
      gap: {{ block.settings.content_gap_desktop }}px;
    }
  }

  .ai-about-relica-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-about-relica-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-about-relica-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: #F5F0E8;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-about-relica-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
    opacity: 0.3;
  }

  .ai-about-relica-content-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-about-relica-heading-{{ ai_gen_id }} {
    font-family: 'Cormorant Garamond', serif;
    font-size: {{ block.settings.heading_size_mobile }}px;
    font-weight: 300;
    line-height: 1.3;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
  }

  @media screen and (min-width: 750px) {
    .ai-about-relica-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_desktop }}px;
    }
  }

  .ai-about-relica-body-{{ ai_gen_id }} {
    font-family: 'DM Sans', sans-serif;
    font-size: {{ block.settings.body_size_mobile }}px;
    line-height: 1.7;
    color: {{ block.settings.body_color }};
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    .ai-about-relica-body-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size_desktop }}px;
    }
  }

  .ai-about-relica-body-{{ ai_gen_id }} p {
    margin: 0 0 20px 0;
  }

  .ai-about-relica-body-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-about-relica-divider-{{ ai_gen_id }} {
    width: {{ block.settings.divider_width }}px;
    height: {{ block.settings.divider_height }}px;
    background-color: {{ block.settings.divider_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    border-radius: 2px;
  }
{% endstyle %}

<div class="ai-about-relica-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-about-relica-container-{{ ai_gen_id }}">
    {% if block.settings.layout != 'text_only' and block.settings.layout == 'image_left' %}
      <div class="ai-about-relica-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 1200 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            class="ai-about-relica-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-about-relica-image-placeholder-{{ ai_gen_id }}">
            {{ 'lifestyle-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-about-relica-content-{{ ai_gen_id }}">
      {% if block.settings.show_divider %}
        <div class="ai-about-relica-divider-{{ ai_gen_id }}"></div>
      {% endif %}

      {% if block.settings.heading != blank %}
        <h2 class="ai-about-relica-heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      {% if block.settings.body_text != blank %}
        <div class="ai-about-relica-body-{{ ai_gen_id }}">
          {{ block.settings.body_text }}
        </div>
      {% endif %}
    </div>

    {% if block.settings.layout == 'image_right' %}
      <div class="ai-about-relica-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 1200 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            class="ai-about-relica-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-about-relica-image-placeholder-{{ ai_gen_id }}">
            {{ 'lifestyle-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "About Relica",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Crafted for Modern Kitchens, Designed for Everyday Living"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text",
      "default": "<p>At Relica, we believe that every kitchen deserves products that combine performance, durability, and elegance. As a modern cookware and kitchen appliances brand, our mission is to transform everyday cooking into a seamless and enjoyable experience.</p><p>We design products that perfectly blend innovation with functionality, helping families cook with comfort, confidence, and convenience. From premium cookware collections to advanced kitchen appliances, every Relica product is thoughtfully crafted to meet the needs of modern households.</p><p>Our focus goes beyond just manufacturing kitchen products — we aim to create reliable solutions that make cooking faster, healthier, and more efficient while adding a touch of sophistication to every kitchen space.</p><p>With a commitment to quality craftsmanship, modern aesthetics, and long-lasting durability, Relica continues to become a trusted companion for homes that value both style and performance.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout style",
      "options": [
        {
          "value": "text_only",
          "label": "Text only"
        },
        {
          "value": "image_left",
          "label": "Image left, text right"
        },
        {
          "value": "image_right",
          "label": "Text left, image right"
        }
      ],
      "default": "image_right"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Container width",
      "min": 800,
      "max": 1400,
      "step": 50,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "Content gap (mobile)",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "content_gap_desktop",
      "label": "Content gap (desktop)",
      "min": 40,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "section_padding_mobile",
      "label": "Section padding (mobile)",
      "min": 30,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_desktop",
      "label": "Section padding (desktop)",
      "min": 50,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Heading bottom spacing",
      "min": 15,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 25
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size (mobile)",
      "min": 24,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading size (desktop)",
      "min": 32,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 42
    },
    {
      "type": "range",
      "id": "body_size_mobile",
      "label": "Body size (mobile)",
      "min": 14,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "body_size_desktop",
      "label": "Body size (desktop)",
      "min": 15,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FDFAF6"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1C3557"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body text color",
      "default": "#2C2C2A"
    },
    {
      "type": "header",
      "content": "Decorative divider"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show divider above heading",
      "default": true
    },
    {
      "type": "range",
      "id": "divider_width",
      "label": "Divider width",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "divider_height",
      "label": "Divider height",
      "min": 2,
      "max": 6,
      "step": 1,
      "unit": "px",
      "default": 3
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider color",
      "default": "#C4827A"
    },
    {
      "type": "header",
      "content": "Image style"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "About Relica"
    }
  ]
}
{% endschema %}