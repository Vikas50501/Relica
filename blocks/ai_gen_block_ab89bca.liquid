{% doc %}
  @prompt
    Create a "Why Choose Relica" section that matches the existing theme's colors, fonts, and style. The section should include:
    
    - A heading: "Why Choose Relica"
    - A subheading: "Innovation, Quality & Performance in Every Product"
    - An introductory paragraph about Relica's design philosophy
    - A grid of 6 feature cards, each with an icon, title, and description:
      1. Premium Quality Materials – high-grade materials for durability and performance
      2. Modern & Elegant Designs – contemporary kitchen aesthetics with practical usability
      3. Safe & Healthy Cooking – food-grade materials and advanced coating technologies
      4. Advanced Engineering – heat distribution, induction compatibility, ergonomic designs
      5. Reliable Everyday Performance – built for daily use with consistent performance
      6. Customer-Focused Innovation – continuously improved based on modern cooking needs
    - A closing statement: "With Relica, you don't just buy cookware or appliances — you invest in quality, reliability, and a better cooking experience for your home."
    
    All text fields should be editable in the theme editor. The layout should be clean and professional, matching the existing theme's typography, color scheme, and spacing. Use the theme's CSS variables for colors and fonts.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-why-choose-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 60px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-why-choose-container-{{ ai_gen_id }} {
    max-width: 1320px;
    margin: 0 auto;
  }

  .ai-why-choose-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 50px;
  }

  .ai-why-choose-heading-{{ ai_gen_id }} {
    font-family: 'Cormorant Garamond', serif;
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 300;
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px 0;
    line-height: 1.2;
  }

  .ai-why-choose-subheading-{{ ai_gen_id }} {
    font-family: 'DM Sans', sans-serif;
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.accent_color }};
    margin: 0 0 24px 0;
    font-weight: 500;
  }

  .ai-why-choose-intro-{{ ai_gen_id }} {
    font-family: 'DM Sans', sans-serif;
    font-size: {{ block.settings.body_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.7;
    max-width: 800px;
    margin: 0 auto;
  }

  .ai-why-choose-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    margin-top: 50px;
  }

  .ai-why-choose-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    padding: 32px 24px;
    border-radius: {{ block.settings.card_border_radius }}px;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-why-choose-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(28, 53, 87, 0.1);
  }

  .ai-why-choose-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.icon_background }};
    border-radius: 50%;
  }

  .ai-why-choose-icon-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.icon_size }}px * 0.5);
    height: calc({{ block.settings.icon_size }}px * 0.5);
    stroke: {{ block.settings.icon_color }};
    fill: none;
  }

  .ai-why-choose-card-title-{{ ai_gen_id }} {
    font-family: 'Cormorant Garamond', serif;
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px 0;
    line-height: 1.3;
  }

  .ai-why-choose-card-desc-{{ ai_gen_id }} {
    font-family: 'DM Sans', sans-serif;
    font-size: {{ block.settings.card_desc_size }}px;
    color: {{ block.settings.text_muted }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-why-choose-closing-{{ ai_gen_id }} {
    text-align: center;
    margin-top: 50px;
    padding-top: 40px;
    border-top: 1px solid {{ block.settings.divider_color }};
  }

  .ai-why-choose-closing-text-{{ ai_gen_id }} {
    font-family: 'DM Sans', sans-serif;
    font-size: {{ block.settings.closing_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.7;
    max-width: 900px;
    margin: 0 auto;
    font-style: italic;
  }

  @media screen and (max-width: 989px) {
    .ai-why-choose-{{ ai_gen_id }} {
      padding: 50px 20px;
    }

    .ai-why-choose-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }

    .ai-why-choose-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-why-choose-subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.9);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-why-choose-{{ ai_gen_id }} {
      padding: 40px 16px;
    }

    .ai-why-choose-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .ai-why-choose-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.65);
    }

    .ai-why-choose-subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.85);
    }

    .ai-why-choose-card-{{ ai_gen_id }} {
      padding: 28px 20px;
    }
  }
{% endstyle %}

