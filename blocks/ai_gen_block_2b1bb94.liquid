{% doc %}
  @prompt
    Create a "Our Vision & Commitment" section for a kitchen products brand called Relica. The section should include:
    
    - A bold heading: "Our Vision & Commitment"
    - A subheading: "Creating Better Kitchen Experiences for Every Home"
    - Four paragraphs of body text: (1) At Relica, our vision is to become a trusted household name known for delivering innovative, reliable, and premium kitchen solutions. We are committed to continuously evolving with modern lifestyles and creating products that combine technology, comfort, and elegance. (2) Our dedication to quality and customer satisfaction drives everything we do. From product design to manufacturing, we maintain strict quality standards to ensure every item reflects excellence and reliability. (3) We believe the kitchen is the heart of every home, and our goal is to make every cooking experience simpler, more enjoyable, and more inspiring through thoughtfully designed products. (4) As we continue to grow, Relica remains committed to innovation, durability, and customer trust — bringing modern kitchen excellence into homes across India and beyond.
    - Clean, professional layout matching the existing Shopify theme with consistent typography, colors, and spacing
    - All text fields editable in the theme editor
    - Use theme's existing font styles and color scheme so it blends seamlessly
    - Subtle decorative divider or accent element between heading and body text
    - Fully responsive for mobile and desktop
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-vision-commitment-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-vision-commitment__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-vision-commitment__heading-{{ ai_gen_id }} {
    font-family: 'Cormorant Garamond', serif;
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    line-height: 1.2;
  }

  .ai-vision-commitment__subheading-{{ ai_gen_id }} {
    font-family: 'DM Sans', sans-serif;
    font-size: {{ block.settings.subheading_size }}px;
    font-weight: 400;
    color: {{ block.settings.subheading_color }};
    margin: 0 0 {{ block.settings.subheading_spacing }}px;
    line-height: 1.5;
  }

  .ai-vision-commitment__divider-{{ ai_gen_id }} {
    width: {{ block.settings.divider_width }}px;
    height: {{ block.settings.divider_height }}px;
    background-color: {{ block.settings.divider_color }};
    margin: 0 auto {{ block.settings.divider_spacing }}px;
    border-radius: {{ block.settings.divider_border_radius }}px;
  }

  .ai-vision-commitment__body-{{ ai_gen_id }} {
    font-family: 'DM Sans', sans-serif;
    font-size: {{ block.settings.body_size }}px;
    line-height: {{ block.settings.body_line_height }};
    color: {{ block.settings.body_color }};
  }

  .ai-vision-commitment__body-{{ ai_gen_id }} p {
    margin: 0 0 {{ block.settings.paragraph_spacing }}px;
  }

  .ai-vision-commitment__body-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-vision-commitment-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.7 }}px {{ block.settings.section_padding_horizontal | times: 0.6 }}px {{ block.settings.section_padding_bottom | times: 0.7 }}px;
    }

    .ai-vision-commitment__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
      margin-bottom: {{ block.settings.heading_spacing | times: 0.8 }}px;
    }

    .ai-vision-commitment__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.85 }}px;
      margin-bottom: {{ block.settings.subheading_spacing | times: 0.8 }}px;
    }

    .ai-vision-commitment__divider-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.divider_spacing | times: 0.8 }}px;
    }

    .ai-vision-commitment__body-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size | times: 0.9 }}px;
    }

    .ai-vision-commitment__body-{{ ai_gen_id }} p {
      margin-bottom: {{ block.settings.paragraph_spacing | times: 0.85 }}px;
    }
  }
{% endstyle %}

<div class="ai-vision-commitment-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-vision-commitment__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-vision-commitment__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <p class="ai-vision-commitment__subheading-{{ ai_gen_id }}">
        {{ block.settings.subheading }}
      </p>
    {% endif %}

    {% if block.settings.show_divider %}
      <div class="ai-vision-commitment__divider-{{ ai_gen_id }}"></div>
    {% endif %}

    <div class="ai-vision-commitment__body-{{ ai_gen_id }}">
      {% if block.settings.paragraph_1 != blank %}
        <p>{{ block.settings.paragraph_1 }}</p>
      {% endif %}

      {% if block.settings.paragraph_2 != blank %}
        <p>{{ block.settings.paragraph_2 }}</p>
      {% endif %}

      {% if block.settings.paragraph_3 != blank %}
        <p>{{ block.settings.paragraph_3 }}</p>
      {% endif %}

      {% if block.settings.paragraph_4 != blank %}
        <p>{{ block.settings.paragraph_4 }}</p>
      {% endif %}
    </div>
  </div>
</div>

