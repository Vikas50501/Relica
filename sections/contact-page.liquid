<section
  id="SeriesTabs-{{ section.id }}"
  class="st-section-{{ section.id }}"
>
  {%- if section.settings.eyebrow != blank or section.settings.title_plain != blank or section.settings.title_italic != blank -%}
    <div class="st-header-{{ section.id }} st-header-reveal-{{ section.id }}">
      {%- if section.settings.eyebrow != blank -%}
        <span class="st-eyebrow-{{ section.id }}">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.title_plain != blank or section.settings.title_italic != blank -%}
        <h2 class="st-title-{{ section.id }}">
          {{ section.settings.title_plain }}
          {%- if section.settings.title_italic != blank %} <em>{{ section.settings.title_italic }}</em>{% endif -%}
        </h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="st-inner-{{ section.id }}">

    <div class="st-tabs-{{ section.id }}">
      {%- for block in section.blocks -%}
        <button
          class="st-tab-{{ section.id }}{% if forloop.first %} st-active-{{ section.id }}{% endif %}"
          data-target="st-panel-{{ section.id }}-{{ forloop.index0 }}"
          type="button"
        >
          {{ block.settings.tab_label }}
        </button>
      {%- endfor -%}
    </div>

    {%- for block in section.blocks -%}
      <div
        id="st-panel-{{ section.id }}-{{ forloop.index0 }}"
        class="st-content-{{ section.id }}{% if forloop.first %} st-active-{{ section.id }}{% endif %}"
        {{ block.shopify_attributes }}
      >
        <div class="st-products-{{ section.id }}">
          {%- assign col = block.settings.collection -%}
          {%- if col != blank and col.products.size > 0 -%}
            {%- for product in col.products limit: block.settings.product_limit -%}
              <a href="{{ product.url }}" class="st-product-link-{{ section.id }}">
                <div class="st-product-card-{{ section.id }}">
                  <div class="st-product-img-{{ section.id }}">
                    {%- if product.featured_image -%}
                      {{ product.featured_image
                        | image_url: width: 500
                        | image_tag:
                          loading: 'lazy',
                          widths: '200, 300, 500',
                          sizes: '(min-width: 990px) 15vw, (min-width: 750px) 20vw, 45vw',
                          alt: product.title
                      }}
                    {%- else -%}
                      <span class="st-product-img-placeholder-{{ section.id }}">{{ product.title }}</span>
                    {%- endif -%}
                  </div>
                  <div class="st-product-info-{{ section.id }}">
                    <p class="st-product-name-{{ section.id }}">{{ product.title }}</p>
                    {%- if section.settings.show_price -%}
                      <p class="st-product-price-{{ section.id }}">{{ product.price | money }}</p>
                    {%- endif -%}
                    {%- if section.settings.show_sku -%}
                      {%- assign sku = product.selected_or_first_available_variant.sku -%}
                      {%- if sku != blank -%}
                        <p class="st-product-sku-{{ section.id }}">{{ sku }}</p>
                      {%- endif -%}
                    {%- endif -%}
                  </div>
                </div>
              </a>
            {%- endfor -%}
          {%- else -%}
            <p class="st-no-products-{{ section.id }}">No products found — please assign a collection to this tab in the theme editor.</p>
          {%- endif -%}
        </div>

        <div class="st-info-{{ section.id }}">
          {%- if block.settings.info_eyebrow != blank -%}
            <span class="st-info-eyebrow-{{ section.id }}">{{ block.settings.info_eyebrow }}</span>
          {%- endif -%}
          {%- if block.settings.info_title_plain != blank or block.settings.info_title_italic != blank -%}
            <h3 class="st-info-title-{{ section.id }}">
              {{ block.settings.info_title_plain }}
              {%- if block.settings.info_title_italic != blank %} <em>{{ block.settings.info_title_italic }}</em>{% endif -%}
            </h3>
          {%- endif -%}
          {%- if block.settings.info_body != blank -%}
            <p class="st-info-body-{{ section.id }}">{{ block.settings.info_body }}</p>
          {%- endif -%}
          {%- if block.settings.features != blank -%}
            <ul class="st-features-{{ section.id }}">
              {%- assign feat_items = block.settings.features | split: '|' -%}
              {%- for item in feat_items -%}
                {%- assign clean_item = item | strip -%}
                {%- if clean_item != blank -%}
                  <li>{{ clean_item }}</li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          {%- endif -%}
          {%- if block.settings.warranty != blank -%}
            <div class="st-warranty-{{ section.id }}">
              <strong>{{ block.settings.warranty }}</strong>&nbsp; Warranty Included
            </div>
          {%- endif -%}
          {%- if block.settings.btn_label != blank -%}
            <a href="{{ block.settings.btn_url | default: '#' }}" class="st-btn-{{ section.id }}">
              {{ block.settings.btn_label }}
              <span class="st-btn-arrow-{{ section.id }}">→</span>
            </a>
          {%- endif -%}
        </div>

      </div>
    {%- endfor -%}
  </div>
</section>

<script>
(function () {
  var sectionEl = document.getElementById('SeriesTabs-{{ section.id }}');
  if (!sectionEl) return;

  var tabs   = sectionEl.querySelectorAll('.st-tab-{{ section.id }}');
  var panels = sectionEl.querySelectorAll('.st-content-{{ section.id }}');
  var active = 'st-active-{{ section.id }}';

  tabs.forEach(function (tab) {
    tab.addEventListener('click', function () {
      var targetId = tab.getAttribute('data-target');
      tabs.forEach(function (t) { t.classList.remove(active); });
      panels.forEach(function (p) { p.classList.remove(active); });
      tab.classList.add(active);
      var panel = document.getElementById(targetId);
      if (panel) panel.classList.add(active);
    });
  });

  var header = sectionEl.querySelector('.st-header-reveal-{{ section.id }}');
  if (!header) return;
  if ('IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          e.target.classList.add('st-visible-{{ section.id }}');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    obs.observe(header);
  } else {
    header.classList.add('st-visible-{{ section.id }}');
  }
})();
</script>

{% schema %}
{
  "name": "Series Tabs",
  "tag": "section",
  "class": "section-series-tabs",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Product Range"
    },
    {
      "type": "text",
      "id": "title_plain",
      "label": "Title — plain text",
      "default": "Browse by"
    },
    {
      "type": "text",
      "id": "title_italic",
      "label": "Title — italic accent",
      "default": "Series"
    },
    {
      "type": "select",
      "id": "header_align",
      "label": "Heading alignment",
      "options": [
        { "value": "left",   "label": "Left"   },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right"  }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "header_spacing",
      "label": "Space below heading",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },

    {
      "type": "header",
      "content": "Typography — Fonts"
    },
    {
      "type": "select",
      "id": "font_display",
      "label": "Display font (titles)",
      "options": [
        { "value": "Cormorant Garamond, serif", "label": "Cormorant Garamond" },
        { "value": "Playfair Display, serif",   "label": "Playfair Display"   },
        { "value": "Libre Baskerville, serif",  "label": "Libre Baskerville"  },
        { "value": "Lora, serif",               "label": "Lora"               },
        { "value": "Georgia, serif",            "label": "Georgia (system)"   },
        { "value": "Times New Roman, serif",    "label": "Times New Roman"    }
      ],
      "default": "Cormorant Garamond, serif"
    },
    {
      "type": "select",
      "id": "font_body",
      "label": "Body font (tabs, labels, text)",
      "options": [
        { "value": "DM Sans, sans-serif",     "label": "DM Sans"            },
        { "value": "Inter, sans-serif",       "label": "Inter"              },
        { "value": "Jost, sans-serif",        "label": "Jost"               },
