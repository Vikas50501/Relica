<style>
  #SeriesTabs-{{ section.id }} {
    /* ── COLOR TOKENS ── */
    --st-bg:              {{ section.settings.section_bg }};
    --st-eyebrow:         {{ section.settings.eyebrow_color }};
    --st-title:           {{ section.settings.title_color }};
    --st-tab-text:        {{ section.settings.tab_text_color }};
    --st-tab-border:      {{ section.settings.tab_border_color }};
    --st-tab-active-line: {{ section.settings.tab_active_bg }};
    --st-tab-active-text: {{ section.settings.tab_active_text }};
    --st-card-bg:         {{ section.settings.card_bg }};
    --st-card-img-bg:     {{ section.settings.card_border_color }};
    --st-card-border:     {{ section.settings.card_border_color }};
    --st-card-name:       {{ section.settings.card_name_color }};
    --st-card-sku:        {{ section.settings.card_sku_color }};
    --st-card-price:      {{ section.settings.card_price_color }};
    --st-info-eyebrow:    {{ section.settings.info_eyebrow_color }};
    --st-info-title:      {{ section.settings.info_title_color }};
    --st-info-body:       {{ section.settings.info_body_color }};
    --st-feat-text:       {{ section.settings.feat_text_color }};
    --st-feat-dot:        {{ section.settings.feat_dot_color }};
    --st-feat-border:     {{ section.settings.feat_border_color }};
    --st-warranty-text:   {{ section.settings.warranty_text_color }};
    --st-btn-bg:          {{ section.settings.btn_bg }};
    --st-btn-text:        {{ section.settings.btn_text_color }};
    --st-btn-hover-bg:    {{ section.settings.btn_hover_bg }};
    --st-btn-hover-text:  {{ section.settings.btn_hover_text }};

    /* ── TYPOGRAPHY TOKENS ── */
    --st-font-display:       {{ section.settings.font_display }};
    --st-font-body:          {{ section.settings.font_body }};
    --st-section-title-size: clamp({{ section.settings.title_size_min }}px, 3vw, {{ section.settings.title_size_max }}px);
    --st-info-title-size:    clamp({{ section.settings.info_title_min }}px, 2.8vw, {{ section.settings.info_title_size }}px);
    --st-eyebrow-size:       {{ section.settings.eyebrow_size }}px;
    --st-eyebrow-spacing:    {{ section.settings.eyebrow_spacing }}em;
    --st-tab-size:           {{ section.settings.tab_font_size }}px;
    --st-tab-spacing:        {{ section.settings.tab_letter_spacing }}em;
    --st-body-size:          {{ section.settings.body_font_size }}px;
    --st-body-line-height:   {{ section.settings.body_line_height }};
    --st-card-name-size:     {{ section.settings.card_name_size }}px;
    --st-card-meta-size:     {{ section.settings.card_meta_size }}px;
    --st-feat-size:          {{ section.settings.feat_font_size }}px;
    --st-btn-size:           {{ section.settings.btn_font_size }}px;
    --st-btn-spacing:        {{ section.settings.btn_letter_spacing }}em;
    --st-warranty-size:      {{ section.settings.warranty_font_size }}px;
  }

  /* ── SECTION ── */
  .st-section-{{ section.id }} {
    background: var(--st-bg);
padding-top: {{ section.settings.padding_top }}px;
padding-bottom: {{ section.settings.padding_bottom }}px;
    font-family: var(--st-font-body);
    -webkit-font-smoothing: antialiased;
  }

  /* ── HEADER ── */
  .st-header-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto {{ section.settings.header_spacing }}px;
    text-align: {{ section.settings.header_align }};
  }

  .st-eyebrow-{{ section.id }} {
    display: block;
    font-family: var(--st-font-body);
    font-size: var(--st-eyebrow-size);
    letter-spacing: var(--st-eyebrow-spacing);
    text-transform: uppercase;
    color: var(--st-eyebrow);
    font-weight: {{ section.settings.eyebrow_weight }};
    margin: 0 0 12px;
  }

  .st-title-{{ section.id }} {
    font-family: var(--st-font-display);
    font-size: var(--st-section-title-size);
    font-weight: {{ section.settings.title_weight }};
    color: var(--st-title);
    line-height: {{ section.settings.title_line_height }};
    margin: 0;
  }

  .st-title-{{ section.id }} em {
    font-style: italic;
    color: var(--st-eyebrow);
  }

  /* ── INNER ── */
  .st-inner-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  /* ── TABS ── */
  .st-tabs-{{ section.id }} {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--st-tab-border);
    margin-bottom: {{ section.settings.tab_spacing }}px;
    flex-wrap: wrap;
  }

  .st-tab-{{ section.id }} {
    padding: {{ section.settings.tab_pad_v }}px {{ section.settings.tab_pad_h }}px;
    font-family: var(--st-font-body);
    font-size: var(--st-tab-size);
    letter-spacing: var(--st-tab-spacing);
    text-transform: uppercase;
    cursor: pointer;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    color: var(--st-tab-text);
    background: none;
    font-weight: {{ section.settings.tab_weight }};
    transition: color .2s ease, border-color .2s ease;
    white-space: nowrap;
  }

  .st-tab-{{ section.id }}.st-active-{{ section.id }} {
    color: var(--st-tab-active-text);
    border-bottom-color: var(--st-tab-active-line);
    font-weight: {{ section.settings.tab_active_weight }};
  }

  .st-tab-{{ section.id }}:hover:not(.st-active-{{ section.id }}) {
    color: var(--st-tab-active-text);
  }

  /* ── PANEL ── */
.st-content-{{ section.id }} {
  display: none;
  grid-template-columns: 1fr; /* stack everything */
  gap: {{ section.settings.panel_gap }}px;
  align-items: start;
}

  .st-content-{{ section.id }}.st-active-{{ section.id }} {
    display: grid;
  }

  /* ── PRODUCTS GRID ── */
  .st-products-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat({{ section.settings.product_columns }}, 1fr);
    gap: {{ section.settings.product_gap }}px;
  }

  /* ── PRODUCT CARD ── */
  .st-product-link-{{ section.id }} {
    text-decoration: none;
    display: block;
  }

  .st-product-card-{{ section.id }} {
    background: var(--st-card-bg);
    overflow: hidden;
    cursor: pointer;
    transition: transform .25s ease, box-shadow .25s ease;
    border-radius: {{ section.settings.card_radius }}px;
    {% if section.settings.card_border %}border: 1px solid var(--st-card-border);{% endif %}
  }

  .st-product-card-{{ section.id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 32px rgba(0,0,0,.07);
  }

  .st-product-img-{{ section.id }} {
    aspect-ratio: 1;
    background: var(--st-card-img-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: {{ section.settings.img_padding }}px;
  }

  .st-product-img-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    transition: transform .4s ease;
  }

  .st-product-card-{{ section.id }}:hover .st-product-img-{{ section.id }} img {
    transform: scale(1.04);
  }

  .st-product-img-placeholder-{{ section.id }} {
    font-family: var(--st-font-display);
    font-size: var(--st-card-meta-size);
    color: var(--st-card-sku);
    text-align: center;
    padding: 8px;
    line-height: 1.4;
  }

  .st-product-info-{{ section.id }} {
    padding: {{ section.settings.card_info_pad }}px;
  }

  .st-product-name-{{ section.id }} {
    font-family: var(--st-font-body);
    font-size: var(--st-card-name-size);
    font-weight: {{ section.settings.card_name_weight }};
    color: var(--st-card-name);
    margin: 0 0 4px;
    line-height: 1.3;
  }

  .st-product-price-{{ section.id }} {
    font-family: var(--st-font-body);
    font-size: var(--st-card-meta-size);
    color: var(--st-card-price);
    font-weight: {{ section.settings.card_meta_weight }};
    margin: 0 0 2px;
  }

  .st-product-sku-{{ section.id }} {
    font-family: var(--st-font-body);
    font-size: var(--st-card-meta-size);
    color: var(--st-card-sku);
    letter-spacing: .04em;
    margin: 0;
    font-weight: {{ section.settings.card_meta_weight }};
  }

  .st-no-products-{{ section.id }} {
    font-family: var(--st-font-body);
    font-size: var(--st-body-size);
    color: var(--st-info-body);
    padding: 20px 0;
    font-style: italic;
  }

  /* ── INFO PANEL ── */
  .st-info-{{ section.id }} {
    position: sticky;
    top: {{ section.settings.info_sticky_top }}px;
  }

  .st-info-eyebrow-{{ section.id }} {
    display: block;
    font-family: var(--st-font-body);
    font-size: var(--st-eyebrow-size);
    letter-spacing: var(--st-eyebrow-spacing);
    text-transform: uppercase;
    color: var(--st-info-eyebrow);
    font-weight: {{ section.settings.eyebrow_weight }};
    margin: 0 0 16px;
  }

  .st-info-title-{{ section.id }} {
    font-family: var(--st-font-display);
    font-size: var(--st-info-title-size);
    font-weight: {{ section.settings.title_weight }};
    color: var(--st-info-title);
    line-height: {{ section.settings.title_line_height }};
    margin: 0 0 18px;
  }

  .st-info-title-{{ section.id }} em {
    font-style: italic;
    color: var(--st-info-eyebrow);
  }

  .st-info-body-{{ section.id }} {
    font-family: var(--st-font-body);
    font-size: var(--st-body-size);
    color: var(--st-info-body);
    line-height: var(--st-body-line-height);
    font-weight: {{ section.settings.body_weight }};
    margin: 0 0 24px;
  }

  /* ── FEATURES LIST ── */
  .st-features-{{ section.id }} {
    list-style: none;
    margin: 0 0 28px;
    padding: 0;
  }

  .st-features-{{ section.id }} li {
    font-family: var(--st-font-body);
    font-size: var(--st-feat-size);
    color: var(--st-feat-text);
    padding: 9px 0;
    border-bottom: 1px solid var(--st-feat-border);
    display: flex;
    align-items: center;
    gap: 12px;
    line-height: 1.4;
    font-weight: {{ section.settings.body_weight }};
  }

  .st-features-{{ section.id }} li::before {
    content: '';
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--st-feat-dot);
    flex-shrink: 0;
  }

  /* ── WARRANTY BADGE ── */
  .st-warranty-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    border: 1px solid var(--st-feat-border);
    padding: 11px 18px;
    font-family: var(--st-font-body);
    font-size: var(--st-warranty-size);
    color: var(--st-warranty-text);
    margin-bottom: 24px;
    font-weight: {{ section.settings.body_weight }};
  }

  .st-warranty-{{ section.id }} strong {
    color: var(--st-info-title);
    font-weight: {{ section.settings.tab_active_weight }};
  }

  /* ── CTA BUTTON ── */
  .st-btn-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--st-btn-bg);
    color: var(--st-btn-text);
    padding: {{ section.settings.btn_pad_v }}px {{ section.settings.btn_pad_h }}px;
    font-family: var(--st-font-body);
    font-size: var(--st-btn-size);
    letter-spacing: var(--st-btn-spacing);
    text-transform: uppercase;
    text-decoration: none;
    font-weight: {{ section.settings.tab_active_weight }};
    border: 1px solid var(--st-btn-bg);
    border-radius: {{ section.settings.btn_radius }}px;
    margin-top: {{ section.settings.btn_margin_top }}px;
    transition: background .25s ease, color .25s ease, border-color .25s ease;
  }

  .st-btn-arrow-{{ section.id }} {
    display: inline-block;
    transition: transform .25s ease;
  }

  .st-btn-{{ section.id }}:hover {
    background: var(--st-btn-hover-bg);
    color: var(--st-btn-hover-text);
    border-color: var(--st-btn-hover-bg);
  }

  .st-btn-{{ section.id }}:hover .st-btn-arrow-{{ section.id }} {
    transform: translateX(4px);
  }

  /* ── HEADER REVEAL ── */
  .st-header-reveal-{{ section.id }} {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity .7s ease, transform .7s ease;
  }

  .st-header-reveal-{{ section.id }}.st-visible-{{ section.id }} {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 990px) {
    .st-content-{{ section.id }}.st-active-{{ section.id }} {
      grid-template-columns: 1fr;
      gap: {{ section.settings.panel_gap | times: 0.6 | round }}px;
    }
    .st-info-{{ section.id }} {
      position: static;
    }
    .st-section-{{ section.id }} {
      padding: {{ section.settings.padding_top | times: 0.75 | round }}px 28px {{ section.settings.padding_bottom | times: 0.75 | round }}px;
    }
  }

  @media (max-width: 749px) {
    .st-products-{{ section.id }} {
      grid-template-columns: repeat(2, 1fr);
    }
    .st-section-{{ section.id }} {
      padding: {{ section.settings.padding_top | times: 0.6 | round }}px 20px {{ section.settings.padding_bottom | times: 0.6 | round }}px;
    }
    .st-tab-{{ section.id }} {
      padding: 10px 14px;
    }
    .st-header-{{ section.id }} {
      text-align: left;
    }
  }

  .arc-carousel__controls{
    bottom:80px !important;
  }

