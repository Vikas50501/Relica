<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">

<style>
  #Features-{{ section.id }} {
    --ft-bg:             {{ section.settings.section_bg }};
    --ft-eyebrow:        {{ section.settings.eyebrow_color }};
    --ft-title:          {{ section.settings.title_color }};
    --ft-card-bg:        {{ section.settings.card_bg }};
    --ft-grid-gap-color: {{ section.settings.grid_line_color }};
    --ft-number:         {{ section.settings.number_color }};
    --ft-card-title:     {{ section.settings.card_title_color }};
    --ft-card-body:      {{ section.settings.card_body_color }};
    --ft-card-border:    {{ section.settings.card_border_color }};
    --ft-accent:         {{ section.settings.accent_color }};
    --ft-pt:             {{ section.settings.padding_top }}px;
    --ft-pb:             {{ section.settings.padding_bottom }}px;
    --ft-radius:         {{ section.settings.card_radius }}px;
  }

  .ft-section-{{ section.id }} {
    background: var(--ft-bg);
    padding: var(--ft-pt) {{ section.settings.side_padding }}px var(--ft-pb);
    font-family: 'DM Sans', sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  /* ── HEADER ── */
  .ft-header-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto {{ section.settings.header_spacing }}px;
    {% if section.settings.header_align == 'center' %}text-align: center;{% elsif section.settings.header_align == 'right' %}text-align: right;{% else %}text-align: left;{% endif %}
  }

  .ft-eyebrow-{{ section.id }} {
    font-size: 11px;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--ft-eyebrow);
    font-weight: 500;
    margin: 0 0 12px;
    display: block;
  }

  .ft-title-{{ section.id }} {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp({{ section.settings.title_size_min }}px, 3vw, {{ section.settings.title_size_max }}px);
    font-weight: 300;
    color: var(--ft-title);
    line-height: 1.15;
    margin: 0;
  }

  .ft-title-{{ section.id }} em {
    font-style: italic;
    color: var(--ft-eyebrow);
  }

  /* ── GRID ── */
  .ft-grid-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: {{ section.settings.card_gap }}px;
    {%- if section.settings.grid_style == 'lines' -%}
    background: var(--ft-grid-gap-color);
    {%- endif -%}
  }

  /* ── CARD ── */
  .ft-card-{{ section.id }} {
    background: var(--ft-card-bg);
    padding: {{ section.settings.card_padding }}px {{ section.settings.card_padding_h }}px;
    position: relative;
    border-radius: var(--ft-radius);
    transition: transform .3s ease, box-shadow .3s ease;
    {%- if section.settings.card_border -%}
    border: 1px solid var(--ft-card-border);
    {%- endif -%}
    {%- if section.settings.grid_style == 'lines' -%}
    border-radius: 0;
    {%- endif -%}
  }

  {%- if section.settings.card_hover -%}
  .ft-card-{{ section.id }}:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(0,0,0,.08);
    z-index: 1;
  }
  {%- endif -%}

  /* accent line on hover */
  {%- if section.settings.show_accent_line -%}
  .ft-card-{{ section.id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--ft-accent);
    transition: width .4s ease;
    border-radius: var(--ft-radius) var(--ft-radius) 0 0;
  }
  .ft-card-{{ section.id }}:hover::before {
    width: 100%;
  }
  {%- endif -%}

  .ft-number-{{ section.id }} {
    font-family: 'Cormorant Garamond', serif;
    font-size: {{ section.settings.number_size }}px;
    font-weight: 300;
    color: var(--ft-number);
    display: block;
    line-height: 1;
    margin-bottom: {{ section.settings.number_spacing }}px;
    {%- if section.settings.number_style == 'outlined' -%}
    -webkit-text-stroke: 1px var(--ft-card-title);
    color: transparent;
    {%- elsif section.settings.number_style == 'accent' -%}
    color: var(--ft-accent);
    opacity: 1;
    {%- endif -%}
  }

  .ft-card-title-{{ section.id }} {
    font-size: {{ section.settings.card_title_size }}px;
    font-weight: 500;
    color: var(--ft-card-title);
    margin: 0 0 12px;
    line-height: 1.3;
    font-family: 'DM Sans', sans-serif;
  }

  .ft-card-body-{{ section.id }} {
    font-size: 14px;
    color: var(--ft-card-body);
    line-height: 1.85;
    font-weight: 300;
    margin: 0;
  }

  /* optional icon */
  .ft-icon-{{ section.id }} {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--ft-accent);
    opacity: .12;
    flex-shrink: 0;
  }

  /* ── REVEAL ── */
  .ft-reveal-{{ section.id }} {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity .7s ease, transform .7s ease;
  }
  .ft-reveal-{{ section.id }}.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .ft-delay-1-{{ section.id }} { transition-delay: .08s; }
  .ft-delay-2-{{ section.id }} { transition-delay: .16s; }
  .ft-delay-3-{{ section.id }} { transition-delay: .24s; }
  .ft-delay-4-{{ section.id }} { transition-delay: .32s; }
  .ft-delay-5-{{ section.id }} { transition-delay: .40s; }
  .ft-delay-6-{{ section.id }} { transition-delay: .48s; }

  /* ── RESPONSIVE ── */
  @media (max-width: 990px) {
    .ft-grid-{{ section.id }} {
      grid-template-columns: repeat({% if section.settings.columns >= 3 %}2{% else %}{{ section.settings.columns }}{% endif %}, 1fr);
    }
    .ft-section-{{ section.id }} {
      padding: {{ section.settings.padding_top | times: 0.75 | round }}px 28px {{ section.settings.padding_bottom | times: 0.75 | round }}px;
    }
  }

  @media (max-width: 749px) {
    .ft-grid-{{ section.id }} {
      grid-template-columns: 1fr;
      gap: {{ section.settings.card_gap | times: 0.6 | round }}px;
      background: none;
    }
    .ft-card-{{ section.id }} {
      {%- if section.settings.grid_style == 'lines' -%}
      border-bottom: 1px solid var(--ft-grid-gap-color);
      border-radius: 0;
      {%- endif -%}
    }
    .ft-section-{{ section.id }} {
      padding: {{ section.settings.padding_top | times: 0.6 | round }}px 20px {{ section.settings.padding_bottom | times: 0.6 | round }}px;
    }
    .ft-header-{{ section.id }} {
      text-align: left;
    }
  }
</style>

<section
  id="Features-{{ section.id }}"
  class="ft-section-{{ section.id }}"
>

  {%- if section.settings.eyebrow != blank or section.settings.title_plain != blank or section.settings.title_italic != blank -%}
    <div class="ft-header-{{ section.id }} ft-reveal-{{ section.id }}">
      {%- if section.settings.eyebrow != blank -%}
        <span class="ft-eyebrow-{{ section.id }}">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.title_plain != blank or section.settings.title_italic != blank -%}
        <h2 class="ft-title-{{ section.id }}">
          {{ section.settings.title_plain }}
          {%- if section.settings.title_italic != blank %} <em>{{ section.settings.title_italic }}</em>{% endif -%}
        </h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="ft-grid-{{ section.id }}">
    {%- for block in section.blocks -%}
      {%- assign delay_index = forloop.index -%}
      {%- if delay_index > 6 -%}{%- assign delay_index = 6 -%}{%- endif -%}

      <div
        class="ft-card-{{ section.id }} ft-reveal-{{ section.id }} ft-delay-{{ delay_index }}-{{ section.id }}"
        {{ block.shopify_attributes }}
      >
        {%- if section.settings.show_number -%}
          <span class="ft-number-{{ section.id }}">
            {{- forloop.index | prepend: '0' | slice: -2, 2 -}}
          </span>
        {%- endif -%}

        {%- if block.settings.title != blank -%}
          <h3 class="ft-card-title-{{ section.id }}">{{ block.settings.title }}</h3>
        {%- endif -%}

        {%- if block.settings.body != blank -%}
          <p class="ft-card-body-{{ section.id }}">{{ block.settings.body }}</p>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

</section>

<script>
  (function () {
    var section = document.getElementById('Features-{{ section.id }}');
    if (!section) return;
    var els = section.querySelectorAll('.ft-reveal-{{ section.id }}');
    if ('IntersectionObserver' in window) {
      var obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            obs.unobserve(e.target);
          }
        });
      }, { threshold: 0.1 });
      els.forEach(function (el) { obs.observe(el); });
    } else {
      els.forEach(function (el) { el.classList.add('visible'); });
    }
  })();
</script>

{% schema %}
{
  "name": "Features",
  "tag": "section",
  "class": "section-features",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Why Relica"
    },
    {
      "type": "text",
      "id": "title_plain",
      "label": "Title — plain text",
      "default": "Engineered for"
    },
    {
      "type": "text",
      "id": "title_italic",
      "label": "Title — italic accent",
      "default": "Perfection"
    },
    {
      "type": "select",
      "id": "header_align",
      "label": "Heading alignment",
      "options": [
        { "value": "left",   "label": "Left"   },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right"  }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "header_spacing",
      "label": "Space below heading",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "title_size_min",
      "label": "Title min size (mobile)",
      "min": 24,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "title_size_max",
      "label": "Title max size (desktop)",
      "min": 36,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 46
    },

    {
      "type": "header",
      "content": "Grid Layout"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "grid_style",
      "label": "Grid style",
      "options": [
        { "value": "lines",  "label": "Hairline dividers" },
        { "value": "cards",  "label": "Floating cards"    },
        { "value": "plain",  "label": "Plain (no border)" }
      ],
      "default": "lines"
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Gap / divider thickness",
      "min": 1,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max content width",
      "min": 800,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1320
    },

    {
      "type": "header",
      "content": "Card Style"
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card top / bottom padding",
      "min": 20,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "card_padding_h",
      "label": "Card left / right padding",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "card_border",
      "label": "Show card border",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "card_hover",
      "label": "Lift card on hover",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_accent_line",
      "label": "Show accent line on hover",
      "info": "A thin color line sweeps across the top of each card.",
      "default": false
    },

    {
      "type": "header",
      "content": "Number Style"
    },
    {
      "type": "checkbox",
      "id": "show_number",
      "label": "Show auto-number",
      "default": true
    },
    {
      "type": "select",
      "id": "number_style",
      "label": "Number style",
      "options": [
        { "value": "muted",    "label": "Muted (faded)"  },
        { "value": "outlined", "label": "Outlined"       },
        { "value": "accent",   "label": "Accent color"   }
      ],
      "default": "muted"
    },
    {
      "type": "range",
      "id": "number_size",
      "label": "Number font size",
      "min": 32,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 52
    },
    {
      "type": "range",
      "id": "number_spacing",
      "label": "Space below number",
      "min": 4,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_title_size",
      "label": "Card title font size",
      "min": 13,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 17
    },

    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#F9F7F4"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#F9F7F4"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow & italic accent",
      "default": "#C4827A"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Heading color",
      "default": "#0F1F33"
    },
    {
      "type": "color",
      "id": "number_color",
      "label": "Number color (muted style)",
      "default": "#D3D1C7"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Card title color",
      "default": "#1C3557"
    },
    {
      "type": "color",
      "id": "card_body_color",
      "label": "Card body text color",
      "default": "#888780"
    },
    {
      "type": "color",
      "id": "grid_line_color",
      "label": "Grid divider / gap color",
      "default": "#D3D1C7"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border color",
      "default": "#D3D1C7"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "info": "Used for hover line and accent number style.",
      "default": "#C4827A"
    },

    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "side_padding",
      "label": "Side padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],

  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 8,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Feature title",
          "default": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Feature description",
          "default": "Describe this feature in a short, compelling sentence or two."
        }
      ]
    }
  ],

  "max_blocks": 8,

  "presets": [
    {
      "name": "Features",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "5-Layer Die-Cast Structure",
            "body": "High-grade die-cast body with exceptional heat distribution. Base coat, mid coat, top coat, and dual spatter layers create a 4mm premium nonstick surface built to last."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Triply Stainless Construction",
            "body": "Three-layer architecture — food-grade SS304, rapid heat-conductive core, and induction-ready SS430 — delivers uniform heating from base to rim with maximum efficiency."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Honeycomb Hybrid Surface",
            "body": "Breakthrough stainless–nonstick fusion. The unique honeycomb pattern minimises sticking, protects the coating, and ensures even cooking across all styles."
          }
        }
      ]
    }
  ]
}
{% endschema %}
