      ],
      "default": "0 1px 4px rgba(0,0,0,.06)"
    },
    {
      "type": "select",
      "id": "card_hover_shadow",
      "label": "Card shadow on hover",
      "options": [
        { "value": "none",                                    "label": "None" },
        { "value": "0 2px 12px rgba(0,0,0,.1)",              "label": "Subtle" },
        { "value": "0 8px 28px rgba(0,0,0,.14)",             "label": "Medium" },
        { "value": "0 16px 48px rgba(0,0,0,.18)",            "label": "Strong" }
      ],
      "default": "0 8px 28px rgba(0,0,0,.14)"
    },
    {
      "type": "range",
      "id": "card_hover_lift",
      "label": "Card lift on hover (px)",
      "min": 0, "max": 12, "step": 1, "default": 4
    },
    {
      "type": "range",
      "id": "card_info_padding",
      "label": "Card info padding (px)",
      "min": 8, "max": 32, "step": 2, "default": 14
    },

    {
      "type": "header",
      "content": "── Product Image ──"
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        { "value": "1",       "label": "Square (1:1)" },
        { "value": "4/5",     "label": "Portrait (4:5)" },
        { "value": "3/4",     "label": "Portrait (3:4)" },
        { "value": "16/9",    "label": "Landscape (16:9)" },
        { "value": "3/2",     "label": "Landscape (3:2)" }
      ],
      "default": "1"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image fit",
      "options": [
        { "value": "cover",   "label": "Cover (fill)" },
        { "value": "contain", "label": "Contain (show all)" }
      ],
      "default": "cover"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Image render width (px)",
      "min": 300, "max": 900, "step": 60, "default": 540
    },
    {
      "type": "checkbox",
      "id": "show_hover_image",
      "label": "Show second image on hover",
      "default": true
