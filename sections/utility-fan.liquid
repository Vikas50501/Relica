{% comment %}
  Arc Carousel
  ------------
  A curved/arc carousel that pulls cards from a linked collection.
  - Cards are arranged on a semicircular arc (7 visible at a time).
  - Each card flips on hover to reveal the product's 2nd image + a short text.
  - Auto-advances on a loop; pauses on hover. Manual prev/next arrows below.
  - Heading + sub-heading sit centered inside the arc.
  - Theme-inherited: uses Shopify's {{ settings.colors_* }} + typography.
  - 100% editable via the section schema + CSS custom properties.
{% endcomment %}

{%- liquid
  assign uid      = section.id | replace: '_', '' | downcase
  assign count    = section.blocks.size
  assign visible  = section.settings.visible_cards | default: 7

  if count < visible
    assign visible = count
  endif
-%}

<section
  class="arc-carousel"
  id="ArcCarousel-{{ uid }}"
  style="
    --arc-bg: {{ section.settings.bg_color }};
    --arc-fg: {{ section.settings.text_color }};
    --arc-card-bg: {{ section.settings.card_bg }};
    --arc-card-shadow: {{ section.settings.card_shadow }};
    --arc-accent: {{ section.settings.accent_color }};
    --arc-card-w: {{ section.settings.card_width }}px;
    --arc-card-h: {{ section.settings.card_height }}px;
    --arc-radius: {{ section.settings.arc_radius }}px;
    --arc-spread: {{ section.settings.arc_spread }}deg;
    --arc-duration: {{ section.settings.autoplay_seconds }}s;
    --arc-pad-y: {{ section.settings.padding_y }}px;
  "
>
  <div class="arc-carousel__inner">

    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="arc-carousel__heading">
        {%- if section.settings.heading != blank -%}
          <h2 class="arc-carousel__title">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p class="arc-carousel__sub">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if count > 0 -%}

      <div
        class="arc-carousel__stage"
        data-arc-stage
        data-visible="{{ visible }}"
        data-count="{{ count }}"
        data-direction="{{ section.settings.direction }}"
        data-autoplay="{{ section.settings.autoplay }}"
      >

        <ul class="arc-carousel__track" data-arc-track>

          {%- for block in section.blocks -%}

            {%- assign category = collections[block.settings.collection] -%}
            {%- assign product = category.products.first -%}

            {%- if product != blank -%}

              {%- liquid
                assign front_img = block.settings.custom_image | default: product.featured_image
                assign back_img = block.settings.custom_image | default: product.featured_image

                if product.images.size > 1
                  assign back_img = product.images[1]
                endif

                assign back_text = product.metafields.custom.arc_back_text | default: product.description | strip_html | truncatewords: 18
              -%}

              <li
                class="arc-carousel__item"
                data-arc-item
                {{ block.shopify_attributes }}
              >

                <div class="arc-carousel__upright">

                  <a
                    class="arc-card"
                    href="{{ category.url }}"
                    aria-label="{{ category.title | escape }}"
                  >

                    <div class="arc-card__inner">

                      <div class="arc-card__face arc-card__face--front">

                        {%- if front_img -%}

                          {{ front_img | image_url: width: 600 | image_tag:
                            loading: 'lazy',
                            widths: '300,450,600',
                            sizes: '(min-width: 750px) 280px, 40vw',
                            class: 'arc-card__img'
                          }}

                        {%- else -%}

                          <div class="arc-card__img arc-card__img--placeholder">
                            {{ 'product-1' | placeholder_svg_tag: 'arc-card__placeholder' }}
                          </div>

                        {%- endif -%}

                        <span class="arc-card__label">
                          {{ category.title | escape }}
                        </span>

                      </div>

                      <div class="arc-card__face arc-card__face--back">

                        {%- if back_img -%}

                          {{ back_img | image_url: width: 600 | image_tag:
                            loading: 'lazy',
                            widths: '300,450,600',
                            sizes: '(min-width: 750px) 280px, 40vw',
                            class: 'arc-card__img'
                          }}

                        {%- else -%}

                          <div class="arc-card__img arc-card__img--placeholder">
                            {{ 'product-2' | placeholder_svg_tag: 'arc-card__placeholder' }}
                          </div>

                        {%- endif -%}

                        <div class="arc-card__back-veil">

                          <span class="arc-card__back-title">
                            {{ category.title | escape }}
                          </span>

                          <span class="arc-card__back-text">
                            {{ back_text }}
                          </span>

                          <span class="arc-card__back-cta">

                            {{ section.settings.cta_label | default: 'Shop now' }}

                            <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
                              <path
                                d="M3 8h9M9 5l3 3-3 3"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                              />
                            </svg>

                          </span>

                        </div>

                      </div>

                    </div>

                  </a>

                </div>

              </li>

            {%- endif -%}

          {%- endfor -%}

        </ul>

      </div>

    {%- endif -%}

  </div>
</section>
<style>
  /* =========================================================
     TYPOGRAPHY: Cormorant Garamond (headings) + DM Sans (body)
     — matches Relica theme settings
     ========================================================= */

  #ArcCarousel-{{ uid }} {
    position: relative;
    background: var(--arc-bg);
    color: var(--arc-fg);
    padding: var(--arc-pad-y) 16px;
    overflow: hidden;
  }

  #ArcCarousel-{{ uid }} .arc-carousel__inner {
    position: relative;
    max-width: 1400px;
    margin: 0 auto;
  }

  /* Heading inside the arc */
  #ArcCarousel-{{ uid }} .arc-carousel__heading {
    position: absolute;
    left: 50%;
    top: 52%;
    transform: translate(-50%, -50%);
    z-index: 3;
    text-align: center;
    pointer-events: none;
    max-width: min(520px, 40vw);
  }
  #ArcCarousel-{{ uid }} .arc-carousel__title {
    /* Cormorant Garamond, Light 300 — mirrors your theme's Display/Heading font */
    font-family: 'Cormorant Garamond', 'Cormorant', Georgia, serif;
    font-weight: 300;
    font-style: normal;
    font-size: clamp(28px, 3.2vw, 44px);
    line-height: 1.08;
    letter-spacing: -0.01em;
    margin: 0 0 10px;
    color: var(--arc-fg);
  }
  #ArcCarousel-{{ uid }} .arc-carousel__sub {
    /* DM Sans — mirrors your theme's Body/UI font */
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: clamp(14px, 1.15vw, 16px);
    line-height: 1.5;
    margin: 0;
    opacity: 0.72;
  }

  /* Stage = the arc area */
  #ArcCarousel-{{ uid }} .arc-carousel__stage {
    position: relative;
    height: calc(var(--arc-radius) * 0.95 + var(--arc-card-h));
    min-height: 440px;
  }

  #ArcCarousel-{{ uid }} .arc-carousel__track {
    list-style: none;
    margin: 0;
    padding: 0;
    position: absolute;
    left: 50%;
    bottom: 0;
    width: 0;
    height: 0;
  }

  /* Each card: 2D arc positioning lives on the <li>. No 3D here. */
  #ArcCarousel-{{ uid }} .arc-carousel__item {
    position: absolute;
    left: 0;
    bottom: 0;
    width: var(--arc-card-w);
    height: var(--arc-card-h);
    margin-left: calc(var(--arc-card-w) / -2);
    margin-bottom: 0;
    transform-origin: 50% 100%;
    opacity: 0;
    pointer-events: none;
    transform: translate(0, 0) rotate(0);
    transition:
      transform 900ms cubic-bezier(.32,.72,.28,1),
      opacity 500ms ease;
    will-change: transform, opacity;
  }

  #ArcCarousel-{{ uid }} .arc-carousel__item[data-active] {
    opacity: 1;
    pointer-events: auto;
    --step: calc(var(--arc-spread) / (var(--n) - 1));
    --angle: calc((var(--slot) - (var(--n) - 1) / 2) * var(--step));
    /* Rotate around the bottom, pushing the card up the arc. */
    transform:
      rotate(var(--angle))
      translateY(calc(var(--arc-radius) * -1));
  }

  /* Upright wrapper: counter-tilts the card slightly so the arc reads naturally
     but text stays legible. Pure 2D — no 3D flattening here. */
  #ArcCarousel-{{ uid }} .arc-carousel__upright {
    width: 100%;
    height: 100%;
    transform: rotate(calc(var(--angle, 0deg) * 0.25));
    transition: transform 900ms cubic-bezier(.32,.72,.28,1);
  }

  /* Flip container gets its OWN 3D context, isolated from the arc rotations. */
  #ArcCarousel-{{ uid }} .arc-card {
    display: block;
    position: relative;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: inherit;
    outline: none;
  }
  #ArcCarousel-{{ uid }} .arc-card__inner {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: var(--arc-card-radius, 14px);
    box-shadow: var(--arc-card-shadow);
    background: var(--arc-card-bg);
    overflow: hidden;
  }
  #ArcCarousel-{{ uid }} .arc-card__face {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    overflow: hidden;
    background: var(--arc-card-bg);
    transition: opacity 450ms ease, transform 600ms cubic-bezier(.2,.7,.2,1);
  }
  #ArcCarousel-{{ uid }} .arc-card__face--front {
    opacity: 1;
    transform: scale(1);
    z-index: 2;
  }
  #ArcCarousel-{{ uid }} .arc-card__face--back {
    opacity: 0;
    transform: scale(1.06);
    z-index: 1;
  }
  #ArcCarousel-{{ uid }} .arc-card:hover .arc-card__face--front,
  #ArcCarousel-{{ uid }} .arc-card:focus-visible .arc-card__face--front {
    opacity: 0;
    transform: scale(1.06);
  }
  #ArcCarousel-{{ uid }} .arc-card:hover .arc-card__face--back,
  #ArcCarousel-{{ uid }} .arc-card:focus-visible .arc-card__face--back {
    opacity: 1;
    transform: scale(1);
    z-index: 3;
  }

  #ArcCarousel-{{ uid }} .arc-card__img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  #ArcCarousel-{{ uid }} .arc-card__img--placeholder {
    display: grid;
    place-items: center;
    background: color-mix(in srgb, var(--arc-fg) 6%, transparent);
  }
  #ArcCarousel-{{ uid }} .arc-card__placeholder { width: 60%; height: 60%; opacity: 0.4; }

  /* Front label strip — DM Sans */
  #ArcCarousel-{{ uid }} .arc-card__label {
    position: absolute;
    left: 10px;
    right: 10px;
    bottom: 12px;
    padding: 8px 12px;
    background: color-mix(in srgb, var(--arc-card-bg) 70%, transparent);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    color: var(--arc-fg);
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-align: center;
    border-radius: 8px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Back face content */
  #ArcCarousel-{{ uid }} .arc-card__back-veil {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 6px;
    padding: 18px 16px 18px;
    background: linear-gradient(
      to top,
      color-mix(in srgb, var(--arc-fg) 88%, transparent) 0%,
      color-mix(in srgb, var(--arc-fg) 70%, transparent) 45%,
      transparent 100%
    );
    color: var(--arc-card-bg);
  }
  /* Back title — Cormorant Garamond Light, matching hero headings */
  #ArcCarousel-{{ uid }} .arc-card__back-title {
    font-family: 'Cormorant Garamond', 'Cormorant', Georgia, serif;
    font-weight: 300;
    font-size: 18px;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }
  /* Back body text — DM Sans */
  #ArcCarousel-{{ uid }} .arc-card__back-text {
    font-family: 'DM Sans', sans-serif;
    font-size: 12.5px;
    line-height: 1.45;
    opacity: 0.85;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  /* CTA — DM Sans uppercase, matching theme buttons */
  #ArcCarousel-{{ uid }} .arc-card__back-cta {
    margin-top: 6px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--arc-accent);
  }

  /* Controls */
  #ArcCarousel-{{ uid }} .arc-carousel__controls {
    position: absolute;
    left: 50%;
    bottom: 8px;
    transform: translateX(-50%);
    display: flex;
    gap: 14px;
    z-index: 4;
  }
  #ArcCarousel-{{ uid }} .arc-carousel__btn {
    width: 44px;
    height: 44px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--arc-fg) 18%, transparent);
    background: var(--arc-card-bg);
    color: var(--arc-fg);
    cursor: pointer;
    display: grid;
    place-items: center;
    transition: transform 180ms ease, background 180ms ease, color 180ms ease;
  }
  #ArcCarousel-{{ uid }} .arc-carousel__btn:hover {
    transform: translateY(-1px);
    background: var(--arc-accent);
    color: var(--arc-card-bg);
    border-color: var(--arc-accent);
  }
  #ArcCarousel-{{ uid }} .arc-carousel__btn:focus-visible {
    outline: 2px solid var(--arc-accent);
    outline-offset: 2px;
  }

  #ArcCarousel-{{ uid }} .arc-carousel__empty {
    text-align: center;
    padding: 40px 16px;
    opacity: 0.6;
    font-family: 'DM Sans', sans-serif;
  }

  /* =========================================================
     MOBILE VIEW (≤ 900px) — improved, desktop untouched
     ========================================================= */
  @media (max-width: 900px) {
    /* Tighten the section padding so the carousel doesn't feel lost in space */
    #ArcCarousel-{{ uid }} {
      padding: clamp(40px, 8vw, 64px) 0;
    }

    #ArcCarousel-{{ uid }} .arc-carousel__inner {
      padding: 0;
    }

    /* Heading: static, centered, with proper breathing room on both sides */
    #ArcCarousel-{{ uid }} .arc-carousel__heading {
      position: static;
      transform: none;
      max-width: 100%;
      margin: 0 auto 28px;
      padding: 0 20px;
      pointer-events: auto;
    }
    #ArcCarousel-{{ uid }} .arc-carousel__title {
      font-size: clamp(26px, 6.5vw, 34px);
      margin-bottom: 8px;
    }
    #ArcCarousel-{{ uid }} .arc-carousel__sub {
      font-size: 14px;
      line-height: 1.5;
      max-width: 420px;
      margin: 0 auto;
    }

    /* Stage collapses to a simple flow container */
    #ArcCarousel-{{ uid }} .arc-carousel__stage {
      height: auto;
      min-height: 0;
      padding: 0;
    }

    /* Horizontal snap scroller with peek-edge padding */
    #ArcCarousel-{{ uid }} .arc-carousel__track {
      position: relative;
      left: 0;
      bottom: auto;
      width: 100%;
      height: auto;
      display: flex;
      gap: 14px;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      scroll-padding-inline: 20px;
      padding: 4px 20px 28px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;            /* Firefox */
    }
    #ArcCarousel-{{ uid }} .arc-carousel__track::-webkit-scrollbar {
      display: none;                    /* WebKit */
    }

    /* Cards: reset all arc transforms, use a clean portrait ratio */
    #ArcCarousel-{{ uid }} .arc-carousel__item {
      position: relative;
      left: auto;
      bottom: auto;
      margin: 0;
      flex: 0 0 auto;
      width: min(68vw, 240px);
      height: auto;
      aspect-ratio: 3 / 4;
      opacity: 1;
      pointer-events: auto;
      transform: none !important;
      transition: none;
      scroll-snap-align: center;
      will-change: auto;
    }
    #ArcCarousel-{{ uid }} .arc-carousel__upright {
      transform: none !important;
    }

    /* Touch devices can't hover — flip on tap via :focus-within as well.
       Also keep the back face readable by default on large-tap screens. */
    #ArcCarousel-{{ uid }} .arc-card:focus-within .arc-card__face--front {
      opacity: 0;
      transform: scale(1.06);
    }
    #ArcCarousel-{{ uid }} .arc-card:focus-within .arc-card__face--back {
      opacity: 1;
      transform: scale(1);
      z-index: 3;
    }

    /* Slightly shorter back-face padding so the CTA doesn't get clipped
       inside the smaller card. */
    #ArcCarousel-{{ uid }} .arc-card__back-veil {
      padding: 14px 14px 14px;
      gap: 4px;
    }
    #ArcCarousel-{{ uid }} .arc-card__back-title { font-size: 16px; }
    #ArcCarousel-{{ uid }} .arc-card__back-text  { font-size: 12px; }

    /* Controls: sit cleanly under the track, full tap targets */
    #ArcCarousel-{{ uid }} .arc-carousel__controls {
      position: static;
      transform: none;
      justify-content: center;
      margin-top: 4px;
      gap: 16px;
    }
    #ArcCarousel-{{ uid }} .arc-carousel__btn {
      width: 42px;
      height: 42px;
    }
    /* Remove hover-lift on touch — it can feel stuck after a tap */
    #ArcCarousel-{{ uid }} .arc-carousel__btn:hover {
      transform: none;
    }
  }

  /* Extra-narrow phones: give cards a bit more of the viewport */
  @media (max-width: 480px) {
    #ArcCarousel-{{ uid }} .arc-carousel__item {
      width: 74vw;
    }
    #ArcCarousel-{{ uid }} .arc-carousel__track {
      gap: 12px;
      padding: 4px 16px 24px;
      scroll-padding-inline: 16px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #ArcCarousel-{{ uid }} .arc-carousel__item,
    #ArcCarousel-{{ uid }} .arc-card__inner {
      transition: none !important;
    }
  }
</style>

<script>
(function () {
  var root = document.getElementById('ArcCarousel-{{ uid }}');
  if (!root) return;
  var stage = root.querySelector('[data-arc-stage]');
  if (!stage) return;

  var items = Array.prototype.slice.call(root.querySelectorAll('[data-arc-item]'));
  var count = items.length;
  var visible = parseInt(stage.getAttribute('data-visible'), 10) || 7;
  if (visible > count) visible = count;
  var dir = (stage.getAttribute('data-direction') || 'rtl');     // 'rtl' or 'ltr'
  var autoplay = (stage.getAttribute('data-autoplay') || 'true') === 'true';
  var durationCss = getComputedStyle(root).getPropertyValue('--arc-duration') || '3s';
  var durationMs = parseFloat(durationCss) * (durationCss.indexOf('ms') > -1 ? 1 : 1000);
  if (!durationMs || isNaN(durationMs)) durationMs = 3000;

  // Detect mobile layout — on mobile the track is a native scroller,
  // so arc painting + autoplay are disabled and prev/next scroll horizontally.
  var mobileMQ = window.matchMedia('(max-width: 900px)');

  var head = 0; // index of the leftmost-visible card in `items`
  var prevSlots = {};

  function slotAngle(slot, visibleN, spread) {
    var step = spread / (visibleN - 1);
    var center = (visibleN - 1) / 2;
    return (slot - center) * step;
  }

  function setAngle(el, angle) {
    el.style.setProperty('--angle', angle + 'deg');
    el.style.setProperty('--upright-angle', (angle * -0.35) + 'deg');
  }

  function clearArcStyles() {
    // When we drop to mobile, wipe inline arc styles so the flex scroller
    // can render cards naturally.
    for (var i = 0; i < items.length; i++) {
      var el = items[i];
      el.removeAttribute('data-active');
      el.style.removeProperty('--angle');
      el.style.removeProperty('--upright-angle');
      el.style.removeProperty('opacity');
      el.style.removeProperty('transform');
      el.style.removeProperty('transition');
      el.style.removeProperty('z-index');
    }
    prevSlots = {};
  }

  function paint() {
    if (mobileMQ.matches) return; // mobile: no arc
    var spread = parseFloat(getComputedStyle(root).getPropertyValue('--arc-spread')) || 130;

    var newSlots = {};
    for (var s = 0; s < visible; s++) {
      var idx = (head + s) % count;
      newSlots[idx] = s;
    }

    // Outgoing: slide past the nearest edge of the arc (no teleport)
    for (var pIdx in prevSlots) {
      if (!(pIdx in newSlots)) {
        var outEl = items[pIdx];
        var wasSlot = prevSlots[pIdx];
        var exitSlot = (wasSlot < visible / 2) ? -1 : visible;
        var exitAngle = slotAngle(exitSlot, visible, spread);
        setAngle(outEl, exitAngle);
        outEl.style.opacity = '0';
        (function (el) {
          setTimeout(function () {
            el.removeAttribute('data-active');
            el.style.removeProperty('--angle');
            el.style.removeProperty('--upright-angle');
            el.style.removeProperty('opacity');
          }, 900);
        })(outEl);
      }
    }

    // Incoming / staying
    for (var idxStr in newSlots) {
      var i = parseInt(idxStr, 10);
      var slot = newSlots[i];
      var el = items[i];
      var angle = slotAngle(slot, visible, spread);
      var wasActive = (i in prevSlots);
      var centerIdx = (visible - 1) / 2;

      if (!wasActive) {
        // Incoming: start off the edge, then slide into slot
        var startSlot = (slot < visible / 2) ? -1 : visible;
        var startAngle = slotAngle(startSlot, visible, spread);
        el.style.transition = 'none';
        el.setAttribute('data-active', '');
        setAngle(el, startAngle);
        el.style.opacity = '0';
        void el.offsetWidth;
        el.style.transition = '';
        setAngle(el, angle);
        el.style.opacity = '1';
      } else {
        el.setAttribute('data-active', '');
        setAngle(el, angle);
      }
      el.style.zIndex = String(100 - Math.abs(slot - centerIdx));
    }

    prevSlots = newSlots;
  }

  function step(delta) {
    if (mobileMQ.matches) {
      // On mobile, prev/next should scroll the track, not rotate an arc.
      var track = root.querySelector('[data-arc-track]');
      if (!track) return;
      var card = track.querySelector('[data-arc-item]');
      var cardW = card ? card.getBoundingClientRect().width : track.clientWidth * 0.7;
      var gap = 14;
      track.scrollBy({ left: delta * (cardW + gap), behavior: 'smooth' });
      return;
    }
    head = (head + delta + count) % count;
    paint();
  }

  paint();

  // Manual controls
  var prev = root.querySelector('[data-arc-prev]');
  var next = root.querySelector('[data-arc-next]');
  if (prev) prev.addEventListener('click', function () { step(-1); bump(); });
  if (next) next.addEventListener('click', function () { step(1);  bump(); });

  // Autoplay with pause-on-hover/focus
  var timer = null;
  var paused = false;
  function tick() {
    if (paused || mobileMQ.matches) return;
    step(dir === 'ltr' ? -1 : 1);
  }
  function start() {
    if (!autoplay || timer || mobileMQ.matches) return;
    timer = setInterval(tick, durationMs);
  }
  function stop() {
    if (timer) { clearInterval(timer); timer = null; }
  }
  function bump() { stop(); start(); }

  stage.addEventListener('mouseenter', function () { paused = true;  });
  stage.addEventListener('mouseleave', function () { paused = false; });
  stage.addEventListener('focusin',    function () { paused = true;  });
  stage.addEventListener('focusout',   function () { paused = false; });

  // Pause when offscreen to save work
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) start(); else stop();
      });
    }, { threshold: 0.15 });
    io.observe(root);
  } else {
    start();
  }

  // React to layout switches between desktop <-> mobile
  function handleMQ() {
    if (mobileMQ.matches) {
      stop();
      clearArcStyles();
    } else {
      head = 0;
      paint();
      start();
    }
  }
  if (mobileMQ.addEventListener) {
    mobileMQ.addEventListener('change', handleMQ);
  } else if (mobileMQ.addListener) {
    mobileMQ.addListener(handleMQ);
  }
  // Run once on load so we start in the right mode
  if (mobileMQ.matches) clearArcStyles();

  // Respect reduced motion
  var mql = window.matchMedia('(prefers-reduced-motion: reduce)');
  if (mql.matches) { autoplay = false; stop(); }
})();
</script>

