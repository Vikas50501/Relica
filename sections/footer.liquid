<footer style="background:{{ settings.footer_bg | default: '#0F1F33' }};color:{{ settings.footer_text | default: '#FFFFFF' }};">
  <div class="footer-inner">
    <div class="footer-top">
      <div>
        <a href="{{ routes.root_url }}" class="footer-logo" style="color:{{ settings.footer_text | default: '#fff' }};">
          {%- if section.settings.logo_image != blank -%}
            <img src="{{ section.settings.logo_image | image_url: width: 200 }}" alt="{{ shop.name }}" style="height:{{ section.settings.logo_height }}px;width:auto;">
          {%- else -%}
            {{ section.settings.logo_text1 }}<em>{{ section.settings.logo_text2 }}</em>
          {%- endif -%}
        </a>
        <p class="footer-tagline">{{ section.settings.tagline }}</p>
        {%- if section.settings.address != blank -%}<p class="footer-contact">{{ section.settings.address }}</p>{%- endif -%}
        {%- if section.settings.phone != blank -%}<p class="footer-contact">{{ section.settings.phone }}</p>{%- endif -%}
        {%- if section.settings.email != blank -%}<p class="footer-contact">{{ section.settings.email }}</p>{%- endif -%}

        {%- if settings.footer_show_social -%}
          <div class="footer-social">
            {%- if settings.footer_instagram != blank -%}
              <a href="{{ settings.footer_instagram }}" aria-label="Instagram" target="_blank" rel="noopener">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              </a>
            {%- endif -%}
            {%- if settings.footer_facebook != blank -%}
              <a href="{{ settings.footer_facebook }}" aria-label="Facebook" target="_blank" rel="noopener">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              </a>
            {%- endif -%}
            {%- if settings.footer_youtube != blank -%}
              <a href="{{ settings.footer_youtube }}" aria-label="YouTube" target="_blank" rel="noopener">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.95C5.12 20 12 20 12 20s6.88 0 8.59-.47a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
              </a>
            {%- endif -%}
            {%- if settings.footer_twitter != blank -%}
              <a href="{{ settings.footer_twitter }}" aria-label="Twitter / X" target="_blank" rel="noopener">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4l16 16M4 20L20 4"/></svg>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'nav_column' -%}
          <div {{ block.shopify_attributes }}>
            <h4 class="footer-col-title">{{ block.settings.title }}</h4>
            <ul class="footer-links">
              {%- for link in linklists[block.settings.menu].links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.show_newsletter -%}
      <div class="footer-newsletter">
        <div class="fn-text">
          <h4 class="fn-title">{{ section.settings.newsletter_title }}</h4>
          {%- if section.settings.newsletter_subtitle != blank -%}
            <p class="fn-sub">{{ section.settings.newsletter_subtitle }}</p>
          {%- endif -%}
        </div>
        <form class="fn-form"
          id="footerNewsletter"
          data-endpoint="{{ section.settings.newsletter_endpoint }}"
          novalidate>
          <div class="fn-row">
            <input type="email"
              name="email"
              class="fn-input"
              placeholder="{{ section.settings.newsletter_placeholder }}"
              autocomplete="email"
              required
              aria-label="Email address">
            <button type="submit" class="fn-btn">
              <span class="fn-btn-label">{{ section.settings.newsletter_button }}</span>
              <span class="fn-btn-spinner" aria-hidden="true"></span>
            </button>
          </div>
          <p class="fn-msg" role="status" aria-live="polite"></p>
        </form>
      </div>
    {%- endif -%}

    <div class="footer-bottom">
      <span>{{ section.settings.copyright }}</span>
      <div class="footer-legal">
        {%- if section.settings.privacy_url != blank -%}<a href="{{ section.settings.privacy_url }}">Privacy Policy</a>{%- endif -%}
        {%- if section.settings.terms_url != blank -%}<a href="{{ section.settings.terms_url }}">Terms of Service</a>{%- endif -%}
        {%- if section.settings.sitemap_url != blank -%}<a href="{{ section.settings.sitemap_url }}">Sitemap</a>{%- endif -%}
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-newsletter{
    display:flex;justify-content:space-between;align-items:center;
    gap:40px;flex-wrap:wrap;
    padding-bottom:32px;margin-bottom:28px;
    border-bottom:1px solid rgba(255,255,255,.08);
  }
  .footer-newsletter .fn-title{
    font-family:var(--font-display);font-size:24px;font-weight:300;
    color:#fff;margin:0 0 6px;
  }
  .footer-newsletter .fn-sub{
    font-size:13px;line-height:1.7;color:rgba(255,255,255,.5);
    font-weight:300;margin:0;max-width:440px;
  }
  .fn-form{min-width:min(440px,100%);flex:0 1 auto;}
  .fn-row{display:flex;align-items:stretch;}
  .fn-input{
    flex:1;min-width:0;background:transparent;
    border:1px solid rgba(255,255,255,.2);border-right:none;
    color:#fff;padding:15px 18px;font-size:14px;
    font-family:var(--font-body);outline:none;transition:border-color .2s;
  }
  .fn-input::placeholder{color:rgba(255,255,255,.4);}
  .fn-input:focus{border-color:var(--rose-mid);}
  /* Button — mirrors the theme's primary CTA (uppercase, .12em, rose accent) */
  .fn-btn{
    position:relative;display:inline-flex;align-items:center;justify-content:center;
    min-width:132px;background:var(--rose-mid);color:var(--navy-deep);border:none;
    padding:15px 32px;font-size:12px;letter-spacing:.12em;
    text-transform:uppercase;font-weight:600;cursor:pointer;
    font-family:var(--font-body);transition:background .25s ease,opacity .2s ease;white-space:nowrap;
  }
  .fn-btn:hover{background:#fff;}
  .fn-btn:disabled{cursor:default;}
  .fn-btn.is-loading{opacity:.92;}
  .fn-btn.is-loading .fn-btn-label{visibility:hidden;}
  .fn-btn-spinner{
    display:none;width:15px;height:15px;border-radius:50%;
    border:2px solid rgba(28,53,87,.3);border-top-color:var(--navy-deep);
    animation:fn-spin .6s linear infinite;
  }
  .fn-btn.is-loading .fn-btn-spinner{display:block;position:absolute;}
  @keyframes fn-spin{to{transform:rotate(360deg);}}
  .fn-msg{font-size:12px;margin:10px 0 0;min-height:1em;font-weight:300;}
  .fn-msg.ok{color:var(--rose-mid);}
  .fn-msg.err{color:#ff9b9b;}
  @media(max-width:768px){
    .footer-newsletter{flex-direction:column;align-items:flex-start;gap:24px;}
    .fn-form{width:100%;}
    .footer-newsletter .fn-title{font-size:21px;}
  }
  /* On small phones, stack the field and button full-width for easy tapping */
  @media(max-width:480px){
    .fn-row{flex-direction:column;gap:10px;}
    .fn-input{border-right:1px solid rgba(255,255,255,.2);text-align:center;}
    .fn-btn{width:100%;}
  }
</style>

<script>
(function(){
  var form = document.getElementById('footerNewsletter');
  if (!form) return;

  var input = form.querySelector('.fn-input');
  var btn   = form.querySelector('.fn-btn');
  var msg   = form.querySelector('.fn-msg');
  var endpoint = form.dataset.endpoint;
  var EMAIL_RE = /^[^@\s]+@[^@\s]+\.[^@\s]+$/;

  form.addEventListener('submit', function (e) {
    e.preventDefault();

    var email = (input.value || '').trim();
    msg.className = 'fn-msg';

    if (!EMAIL_RE.test(email)) {
      msg.textContent = 'Please enter a valid email address.';
      msg.classList.add('err');
      return;
    }

    if (!endpoint) {
      msg.textContent = 'Newsletter is not configured yet.';
      msg.classList.add('err');
      return;
    }

    btn.disabled = true;
    btn.classList.add('is-loading');

    var data = new URLSearchParams();
    data.append('email', email);
    data.append('source', window.location.hostname);

    // Google Apps Script web apps don't send CORS headers, so we POST
    // with no-cors (opaque response) — the row is still written to the sheet.
    fetch(endpoint, { method: 'POST', mode: 'no-cors', body: data })
      .then(function () {
        msg.textContent = 'Thanks for subscribing!';
        msg.classList.add('ok');
        form.reset();
      })
      .catch(function () {
        msg.textContent = 'Something went wrong. Please try again.';
        msg.classList.add('err');
      })
      .finally(function () {
        btn.disabled = false;
        btn.classList.remove('is-loading');
      });
  });
})();
</script>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "header", "content": "Logo" },
    { "type": "image_picker", "id": "logo_image", "label": "Logo image" },
    { "type": "range", "id": "logo_height", "label": "Logo height (px)", "min": 20, "max": 80, "step": 2, "default": 36 },
    { "type": "text", "id": "logo_text1", "label": "Logo text — part 1", "default": "Relic" },
    { "type": "text", "id": "logo_text2", "label": "Logo text — italic part", "default": "a" },
    { "type": "header", "content": "Brand Info" },
    { "type": "textarea", "id": "tagline", "label": "Tagline" },
    { "type": "text", "id": "address", "label": "Address" },
    { "type": "text", "id": "phone", "label": "Phone" },
    { "type": "text", "id": "email", "label": "Email" },
    { "type": "header", "content": "Newsletter" },
    { "type": "checkbox", "id": "show_newsletter", "label": "Show newsletter signup", "default": true },
    { "type": "text", "id": "newsletter_title", "label": "Heading", "default": "Join the Relica family" },
    { "type": "textarea", "id": "newsletter_subtitle", "label": "Subtext", "default": "Subscribe for new launches, exclusive offers, and culinary inspiration." },
    { "type": "text", "id": "newsletter_placeholder", "label": "Input placeholder", "default": "Enter your email" },
    { "type": "text", "id": "newsletter_button", "label": "Button label", "default": "Subscribe" },
    { "type": "text", "id": "newsletter_endpoint", "label": "Google Sheet endpoint URL", "info": "Paste the /exec Web App URL from your Google Apps Script deployment (see setup steps). Emails submitted in the footer are appended to your sheet." },
    { "type": "header", "content": "Legal" },
    { "type": "text", "id": "copyright", "label": "Copyright text", "default": "© 2026 Relica Innovations Pvt. Ltd. All rights reserved." },
    { "type": "url", "id": "privacy_url", "label": "Privacy Policy URL" },
    { "type": "url", "id": "terms_url", "label": "Terms of Service URL" },
    { "type": "url", "id": "sitemap_url", "label": "Sitemap URL" }
  ],
  "blocks": [
    {
      "type": "nav_column",
      "name": "Footer Column",
      "settings": [
        { "type": "text", "id": "title", "label": "Column title", "default": "Shop Now" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "presets": [{ "name": "Footer" }]
}
{% endschema %}
