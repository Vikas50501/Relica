{%- assign height_class = section.settings.height | default: 'medium' -%}
<div class="page-hero page-hero--{{ height_class }}" style="background:{{ section.settings.bg_color }};color:{{ section.settings.text_color }};">
  <div class="page-hero-inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="section-eyebrow" style="color:{{ section.settings.text_color | color_mix: '#888780', 50 }};">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h1 class="page-hero-title">{{ section.settings.title }}</h1>
    {%- if section.settings.subtitle != blank -%}
      <p class="page-hero-sub">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    {%- if section.settings.btn_label != blank -%}
      <a href="{{ section.settings.btn_url }}" class="btn-primary" style="margin-top:28px;display:inline-block;">{{ section.settings.btn_label }}</a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Page Hero",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Our Story" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Page Title" },
    { "type": "textarea", "id": "subtitle", "label": "Subheading" },
    { "type": "text", "id": "btn_label", "label": "Button label (optional)" },
    { "type": "url", "id": "btn_url", "label": "Button URL" },
    { "type": "header", "content": "Style" },
    {
      "type": "select",
      "id": "height",
      "label": "Hero height",
      "default": "medium",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ]
    },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#1C3557" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#FFFFFF" },
    { "type": "image_picker", "id": "bg_image", "label": "Background image (optional)" },
    { "type": "range", "id": "overlay_opacity", "label": "Image overlay opacity (%)", "min": 0, "max": 90, "step": 5, "default": 50 }
  ],
  "presets": [{ "name": "Page Hero" }]
}
{% endschema %}
