<div
  class="col-hero {% if section.settings.image != blank or collection.image != blank %}col-hero--has-image{% endif %}"
  style="
    {% if section.settings.image == blank and collection.image == blank %}background:{{ section.settings.bg_color }};{% endif %}
    min-height:{{ section.settings.section_height }}px;
    {% if section.settings.content_align == 'left' %}--content-align: flex-start; --text-align: left;{% elsif section.settings.content_align == 'right' %}--content-align: flex-end; --text-align: right;{% else %}--content-align: center; --text-align: center;{% endif %}
    --content-padding-x: {{ section.settings.content_padding_x }}px;
    --content-padding-y: {{ section.settings.content_padding_y }}px;
    --content-max-width: {{ section.settings.content_max_width }}px;
  "
>

  {%- if section.settings.image != blank -%}
    <div class="col-hero-bg">
      <img
        src="{{ section.settings.image | image_url: width: 2000 }}"
        alt="{{ collection.title }}"
        loading="eager"
        style="object-position: {{ section.settings.image_focal_x }}% {{ section.settings.image_focal_y }}%;"
      >
      <div
        class="col-hero-overlay"
        style="
          opacity:{{ section.settings.overlay_opacity | divided_by: 100.0 }};
          background:{{ section.settings.overlay_color }};
          mix-blend-mode:{{ section.settings.overlay_blend_mode }};
        "
      ></div>
    </div>
  {%- elsif collection.image != blank -%}
    <div class="col-hero-bg">
      <img
        src="{{ collection.image | image_url: width: 2000 }}"
        alt="{{ collection.title }}"
        loading="eager"
        style="object-position: {{ section.settings.image_focal_x }}% {{ section.settings.image_focal_y }}%;"
      >
      <div
        class="col-hero-overlay"
        style="
          opacity:{{ section.settings.overlay_opacity | divided_by: 100.0 }};
          background:{{ section.settings.overlay_color }};
          mix-blend-mode:{{ section.settings.overlay_blend_mode }};
        "
      ></div>
    </div>
  {%- else -%}
    <div class="col-hero-bg col-hero-bg--pattern"></div>
  {%- endif -%}

  <div class="col-hero-content">
    <div class="col-hero-inner">

      {%- if section.settings.show_breadcrumb -%}
        <nav class="col-breadcrumb" aria-label="Breadcrumb" style="color:{{ section.settings.breadcrumb_color }};">
          <a href="{{ routes.root_url }}" style="color:{{ section.settings.breadcrumb_color }};">Home</a>
          <span class="col-breadcrumb-sep">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="9 18 15 12 9 6"/></svg>
          </span>
          <span>{{ collection.title }}</span>
        </nav>
      {%- endif -%}

      {%- if section.settings.show_eyebrow and section.settings.eyebrow != blank -%}
        <p
          class="col-hero-eyebrow"
          style="
            color:{{ section.settings.eyebrow_color }};
            font-size:{{ section.settings.eyebrow_font_size }}px;
            letter-spacing:{{ section.settings.eyebrow_letter_spacing }}em;
            text-transform:{{ section.settings.eyebrow_transform }};
          "
        >{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.show_title -%}
        <h1
          class="col-hero-title"
          style="
            color:{{ section.settings.title_color }};
            font-size:{{ section.settings.title_font_size }}px;
            line-height:{{ section.settings.title_line_height }};
            font-weight:{{ section.settings.title_font_weight }};
            text-transform:{{ section.settings.title_transform }};
          "
        >{{ section.settings.title_custom | default: collection.title }}</h1>
      {%- endif -%}

      {%- if section.settings.show_description -%}
        {%- if collection.description != blank and section.settings.prefer_collection_desc -%}
          <p
            class="col-hero-desc"
            style="
              color:{{ section.settings.desc_color }};
              font-size:{{ section.settings.desc_font_size }}px;
              max-width:{{ section.settings.desc_max_width }}px;
              opacity:{{ section.settings.desc_opacity | divided_by: 100.0 }};
            "
          >{{ collection.description | strip_html | truncate: section.settings.desc_truncate }}</p>
        {%- elsif section.settings.description != blank -%}
          <p
            class="col-hero-desc"
            style="
              color:{{ section.settings.desc_color }};
              font-size:{{ section.settings.desc_font_size }}px;
              max-width:{{ section.settings.desc_max_width }}px;
              opacity:{{ section.settings.desc_opacity | divided_by: 100.0 }};
            "
          >{{ section.settings.description }}</p>
        {%- endif -%}
      {%- endif -%}

      {%- if section.settings.show_product_count or section.settings.show_button -%}
        <div class="col-hero-meta" style="justify-content:{% if section.settings.content_align == 'center' %}center{% elsif section.settings.content_align == 'right' %}flex-end{% else %}flex-start{% endif %};">

          {%- if section.settings.show_product_count -%}
            <span
              class="col-hero-count"
              style="
                color:{{ section.settings.badge_text_color }};
                background:{{ section.settings.badge_bg_color }};
                border-radius:{{ section.settings.badge_border_radius }}px;
                font-size:{{ section.settings.badge_font_size }}px;
              "
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
              {{ collection.products_count }} {{ section.settings.product_count_label | default: 'Products' }}
            </span>
          {%- endif -%}

          {%- if section.settings.show_button and section.settings.button_label != blank -%}
            <a
              href="{{ section.settings.button_url | default: '#' }}"
              class="col-hero-btn"
              style="
                color:{{ section.settings.button_text_color }};
                background:{{ section.settings.button_bg_color }};
                border:{{ section.settings.button_border_width }}px solid {{ section.settings.button_border_color }};
                border-radius:{{ section.settings.button_border_radius }}px;
                font-size:{{ section.settings.button_font_size }}px;
                padding:{{ section.settings.button_padding_y }}px {{ section.settings.button_padding_x }}px;
              "
            >{{ section.settings.button_label }}</a>
          {%- endif -%}

        </div>
      {%- endif -%}

    </div>
  </div>
</div>

<style>
  .col-hero {
    position: relative;
    display: flex;
    align-items: var(--vertical-align, center);
    justify-content: var(--content-align, flex-start);
    min-height: 420px;
    overflow: hidden;
  }
  .col-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .col-hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .col-hero-bg--pattern {
    background-image: radial-gradient(circle, rgba(0,0,0,0.06) 1px, transparent 1px);
    background-size: 20px 20px;
  }
  .col-hero-overlay {
    position: absolute;
    inset: 0;
  }
  .col-hero-content {
    position: relative;
    z-index: 1;
    width: 100%;
    padding: var(--content-padding-y, 60px) var(--content-padding-x, 40px);
  }
  .col-hero-inner {
    max-width: var(--content-max-width, 680px);
    text-align: var(--text-align, left);
  }
  .col-hero--has-image .col-hero-inner { margin: 0 auto; }
  .col-breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    margin-bottom: 16px;
    flex-wrap: wrap;
    justify-content: var(--content-align, flex-start);
  }
  .col-breadcrumb a { text-decoration: none; opacity: 0.8; }
  .col-breadcrumb a:hover { opacity: 1; text-decoration: underline; }
  .col-breadcrumb-sep { opacity: 0.5; display: flex; }
  .col-hero-eyebrow {
    margin: 0 0 10px;
    font-weight: 600;
  }
  .col-hero-title {
    margin: 0 0 16px;
  }
  .col-hero-desc {
    margin: 0 0 24px;
    line-height: 1.6;
  }
  .col-hero-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .col-hero-count {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    font-weight: 500;
  }
  .col-hero-btn {
    display: inline-block;
    text-decoration: none;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .col-hero-btn:hover { opacity: 0.85; }
</style>

{% schema %}
{
  "name": "Collection Hero",
  "settings": [
    {
      "type": "header",
      "content": "📐 Layout"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Section Min Height (px)",
      "min": 200,
      "max": 900,
      "step": 20,
      "default": 420
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Content Horizontal Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "content_padding_x",
      "label": "Content Padding Horizontal (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "content_padding_y",
      "label": "Content Padding Vertical (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content Max Width (px)",
      "min": 300,
      "max": 1400,
      "step": 20,
      "default": 680
    },

    {
      "type": "header",
      "content": "🖼️ Background Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image (overrides collection image)"
    },
    {
      "type": "range",
      "id": "image_focal_x",
      "label": "Image Focal Point X (%)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50
    },
    {
      "type": "range",
      "id": "image_focal_y",
      "label": "Image Focal Point Y (%)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color (no image fallback)",
      "default": "#F5F0E8"
    },

    {
      "type": "header",
      "content": "🎨 Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#0F1F33"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity (%)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 55
    },
    {
      "type": "select",
      "id": "overlay_blend_mode",
      "label": "Overlay Blend Mode",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "multiply", "label": "Multiply" },
        { "value": "screen", "label": "Screen" },
        { "value": "overlay", "label": "Overlay" },
        { "value": "darken", "label": "Darken" },
        { "value": "lighten", "label": "Lighten" },
        { "value": "color-burn", "label": "Color Burn" },
        { "value": "color-dodge", "label": "Color Dodge" },
        { "value": "soft-light", "label": "Soft Light" },
        { "value": "hard-light", "label": "Hard Light" }
      ],
      "default": "normal"
    },

    {
      "type": "header",
      "content": "🧭 Breadcrumb"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Show Breadcrumb",
      "default": true
    },
    {
      "type": "color",
      "id": "breadcrumb_color",
      "label": "Breadcrumb Color",
      "default": "#FFFFFF"
    },

    {
      "type": "header",
      "content": "🏷️ Eyebrow Label"
    },
    {
      "type": "checkbox",
      "id": "show_eyebrow",
      "label": "Show Eyebrow",
      "default": true
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Our Collection"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow Color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "eyebrow_font_size",
      "label": "Eyebrow Font Size (px)",
      "min": 10,
      "max": 24,
      "step": 1,
      "default": 13
    },
    {
      "type": "range",
      "id": "eyebrow_letter_spacing",
      "label": "Eyebrow Letter Spacing (em × 0.01)",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 10,
      "info": "Value is multiplied by 0.01em. e.g. 10 = 0.10em"
    },
    {
      "type": "select",
      "id": "eyebrow_transform",
      "label": "Eyebrow Text Transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "lowercase", "label": "Lowercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "uppercase"
    },

    {
      "type": "header",
      "content": "📝 Title"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show Title",
      "default": true
    },
    {
      "type": "text",
      "id": "title_custom",
      "label": "Custom Title (leave blank to use collection title)"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Title Font Size (px)",
      "min": 24,
      "max": 100,
      "step": 2,
      "default": 48
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "Title Font Weight",
      "options": [
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semibold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extrabold (800)" },
        { "value": "900", "label": "Black (900)" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "title_line_height",
      "label": "Title Line Height",
      "options": [
        { "value": "1", "label": "Tight (1.0)" },
        { "value": "1.1", "label": "1.1" },
        { "value": "1.2", "label": "1.2" },
        { "value": "1.3", "label": "1.3" },
        { "value": "1.4", "label": "Normal (1.4)" },
        { "value": "1.6", "label": "Relaxed (1.6)" }
      ],
      "default": "1.1"
    },
    {
      "type": "select",
      "id": "title_transform",
      "label": "Title Text Transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "lowercase", "label": "Lowercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },

    {
      "type": "header",
      "content": "📄 Description"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show Description",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "prefer_collection_desc",
      "label": "Prefer Collection Description (if available)",
      "default": true
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Custom Description (fallback)"
    },
    {
      "type": "color",
      "id": "desc_color",
      "label": "Description Color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "desc_font_size",
      "label": "Description Font Size (px)",
      "min": 12,
      "max": 28,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "desc_opacity",
      "label": "Description Opacity (%)",
      "min": 30,
      "max": 100,
      "step": 5,
      "default": 85
    },
    {
      "type": "range",
      "id": "desc_max_width",
      "label": "Description Max Width (px)",
      "min": 200,
      "max": 900,
      "step": 20,
      "default": 560
    },
    {
      "type": "range",
      "id": "desc_truncate",
      "label": "Collection Description Truncate (characters)",
      "min": 60,
      "max": 400,
      "step": 10,
      "default": 160
    },

    {
      "type": "header",
      "content": "🔢 Product Count Badge"
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show Product Count",
      "default": true
    },
    {
      "type": "text",
      "id": "product_count_label",
      "label": "Product Count Label",
      "default": "Products"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Badge Background Color",
      "default": "#FFFFFF20"
    },
    {
      "type": "range",
      "id": "badge_font_size",
      "label": "Badge Font Size (px)",
      "min": 11,
      "max": 20,
      "step": 1,
      "default": 13
    },
    {
      "type": "range",
      "id": "badge_border_radius",
      "label": "Badge Border Radius (px)",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 20
    },

    {
      "type": "header",
      "content": "🔘 CTA Button"
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Show Button",
      "default": false
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#0F1F33"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Button Border Color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "button_border_width",
      "label": "Button Border Width (px)",
      "min": 0,
      "max": 6,
      "step": 1,
      "default": 0
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button Border Radius (px)",
      "min": 0,
      "max": 60,
      "step": 2,
      "default": 6
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Button Font Size (px)",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "button_padding_x",
      "label": "Button Padding Horizontal (px)",
      "min": 8,
      "max": 80,
      "step": 2,
      "default": 24
    },
    {
      "type": "range",
      "id": "button_padding_y",
      "label": "Button Padding Vertical (px)",
      "min": 4,
      "max": 40,
      "step": 2,
      "default": 12
    }
  ],
  "enabled_on": { "templates": ["collection"] }
}
{% endschema %}
