        { "value": "3/4",  "label": "3 : 4  (portrait)" },
        { "value": "1/1",  "label": "1 : 1  (square)" },
        { "value": "16/9", "label": "16 : 9 (wide)" }
      ],
      "default": "4/5"
    },
    {
      "type": "color",
      "id": "main_image_color",
      "label": "Main image fallback color",
      "default": "#24436B"
    },
    {
      "type": "color_background",
      "id": "main_image_gradient",
      "label": "Main image fallback gradient",
      "info": "Overrides solid color when set.",
      "default": "linear-gradient(160deg, #24436B, #0F1F33)"
    },
    {
      "type": "text",
      "id": "main_image_label",
      "label": "Main image placeholder text",
