<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">

<style>
  #Compat-{{ section.id }} {
    --cp-bg:             {{ section.settings.section_bg }};
    --cp-title:          {{ section.settings.title_color }};
    --cp-sub:            {{ section.settings.subtitle_color }};
    --cp-circle-border:  {{ section.settings.circle_border_color }};
    --cp-circle-bg:      {{ section.settings.circle_bg_color }};
    --cp-circle-hover-border: {{ section.settings.circle_hover_border }};
    --cp-circle-hover-bg:     {{ section.settings.circle_hover_bg }};
    --cp-icon:           {{ section.settings.icon_color }};
    --cp-label:          {{ section.settings.label_color }};
    --cp-label-hover:    {{ section.settings.label_hover_color }};
    --cp-divider:        {{ section.settings.divider_color }};
    --cp-pt:             {{ section.settings.padding_top }}px;
    --cp-pb:             {{ section.settings.padding_bottom }}px;
    --cp-radius:         {% if section.settings.circle_radius >= 100 %}9999px{% else %}{{ section.settings.circle_radius }}px{% endif %};
    --cp-circle-size:    {{ section.settings.circle_size }}px;
    --cp-icon-size:      {{ section.settings.icon_size }}px;
    --cp-gap:            {{ section.settings.icon_gap }}px;
  }

  .cp-section-{{ section.id }} {
    background: var(--cp-bg);
    padding: var(--cp-pt) {{ section.settings.side_padding }}px var(--cp-pb);
    font-family: 'DM Sans', sans-serif;
    -webkit-font-smoothing: antialiased;
    text-align: center;
  }

  .cp-inner-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  /* ── HEADING ── */
  .cp-title-{{ section.id }} {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp({{ section.settings.title_size_min }}px, 3vw, {{ section.settings.title_size_max }}px);
    font-weight: 300;
    color: var(--cp-title);
    margin: 0 0 10px;
    line-height: 1.15;
  }

  .cp-title-{{ section.id }} em {
    font-style: italic;
    color: {{ section.settings.title_italic_color }};
  }

  .cp-sub-{{ section.id }} {
    font-size: 14px;
    color: var(--cp-sub);
    font-weight: 300;
    margin: 0 0 {{ section.settings.header_spacing }}px;
    line-height: 1.7;
    max-width: 540px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── DIVIDER ── */
  {%- if section.settings.show_divider -%}
  .cp-divider-{{ section.id }} {
    width: 40px;
    height: 1px;
    background: var(--cp-divider);
    margin: 0 auto {{ section.settings.header_spacing }}px;
  }
  {%- endif -%}

  /* ── ICONS GRID ── */
  .cp-icons-{{ section.id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--cp-gap);
  }

  .cp-item-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ section.settings.label_gap }}px;
    cursor: default;
  }

  .cp-circle-{{ section.id }} {
    width: var(--cp-circle-size);
    height: var(--cp-circle-size);
    border: 1px solid var(--cp-circle-border);
    border-radius: var(--cp-radius);
    background: var(--cp-circle-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color .25s ease, background .25s ease, transform .25s ease;
  }

  .cp-circle-{{ section.id }} svg {
    width: var(--cp-icon-size);
    height: var(--cp-icon-size);
    stroke: var(--cp-icon);
    fill: none;
    stroke-width: 1.5;
    flex-shrink: 0;
    transition: stroke .25s ease;
  }

  .cp-item-{{ section.id }}:hover .cp-circle-{{ section.id }} {
    border-color: var(--cp-circle-hover-border);
    background: var(--cp-circle-hover-bg);
    transform: translateY(-4px);
  }

  .cp-item-{{ section.id }}:hover .cp-circle-{{ section.id }} svg {
    stroke: {{ section.settings.icon_hover_color }};
  }

  .cp-label-{{ section.id }} {
    font-size: {{ section.settings.label_size }}px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--cp-label);
    font-weight: 400;
    transition: color .25s ease;
  }

  .cp-item-{{ section.id }}:hover .cp-label-{{ section.id }} {
    color: var(--cp-label-hover);
  }

  /* ── BADGE strip (optional) ── */
  {%- if section.settings.show_badge -%}
  .cp-badge-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--cp-circle-border);
    padding: 10px 22px;
    font-size: 12px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--cp-sub);
    margin-top: {{ section.settings.header_spacing }}px;
    font-weight: 300;
  }
  .cp-badge-dot-{{ section.id }} {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: {{ section.settings.divider_color }};
    flex-shrink: 0;
  }
  {%- endif -%}

  /* ── REVEAL ── */
  .cp-reveal-{{ section.id }} {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity .7s ease, transform .7s ease;
  }
  .cp-reveal-{{ section.id }}.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 749px) {
    .cp-section-{{ section.id }} {
      padding: {{ section.settings.padding_top | times: 0.7 | round }}px 24px {{ section.settings.padding_bottom | times: 0.7 | round }}px;
    }
    .cp-icons-{{ section.id }} {
      gap: calc(var(--cp-gap) * 0.7);
    }
    .cp-circle-{{ section.id }} {
      width: calc(var(--cp-circle-size) * 0.85);
      height: calc(var(--cp-circle-size) * 0.85);
    }
  }
</style>

<section
  id="Compat-{{ section.id }}"
  class="cp-section-{{ section.id }}"
>
  <div class="cp-inner-{{ section.id }} cp-reveal-{{ section.id }}">

    {%- if section.settings.title != blank -%}
      <h2 class="cp-title-{{ section.id }}">
        {{- section.settings.title -}}
      </h2>
    {%- endif -%}

    {%- if section.settings.subtitle != blank -%}
      <p class="cp-sub-{{ section.id }}">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    {%- if section.settings.show_divider -%}
      <div class="cp-divider-{{ section.id }}"></div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="cp-icons-{{ section.id }}">
        {%- for block in section.blocks -%}
          <div class="cp-item-{{ section.id }}" {{ block.shopify_attributes }}>
            <div class="cp-circle-{{ section.id }}">
              {%- case block.settings.icon -%}

                {%- when 'gas' -%}
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="5"/><path d="M12 2v3M12 19v3M3 12h3M18 12h3"/></svg>

                {%- when 'induction' -%}
                <svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M7 10h10M7 14h6"/></svg>

                {%- when 'electric' -%}
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="4"/><path d="M12 3v2M12 19v2M3 12h2M19 12h2M5.6 5.6l1.4 1.4M16.9 16.9l1.4 1.4M18.4 5.6l-1.4 1.4M7.1 16.9l-1.4 1.4"/></svg>

                {%- when 'ceramic' -%}
                <svg viewBox="0 0 24 24"><ellipse cx="12" cy="12" rx="9" ry="5"/><path d="M3 12c0 4 4 7 9 7s9-3 9-7"/></svg>

                {%- when 'halogen' -%}
                <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>

                {%- when 'dishwasher' -%}
                <svg viewBox="0 0 24 24"><path d="M4 7h16M4 12h10"/><circle cx="17" cy="17" r="3"/></svg>

                {%- when 'oven' -%}
                <svg viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="18" rx="2"/><rect x="6" y="8" width="12" height="10" rx="1"/><circle cx="8" cy="6" r=".8" fill="currentColor"/><circle cx="12" cy="6" r=".8" fill="currentColor"/><circle cx="16" cy="6" r=".8" fill="currentColor"/></svg>

                {%- when 'microwave' -%}
                <svg viewBox="0 0 24 24"><rect x="2" y="6" width="20" height="14" rx="2"/><rect x="4" y="8" width="12" height="10" rx="1"/><path d="M18 10h1M18 13h1M18 16h1"/></svg>

                {%- when 'bbq' -%}
                <svg viewBox="0 0 24 24"><path d="M4 11h16a8 8 0 0 1-16 0z"/><path d="M12 19v3M9 22h6"/><path d="M8 4c0 2 2 2 2 4M12 4c0 2 2 2 2 4"/></svg>

                {%- when 'custom' -%}
                {%- if block.settings.custom_svg != blank -%}
                  {{ block.settings.custom_svg }}
                {%- else -%}
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="7"/><path d="M12 8v4l3 3"/></svg>
                {%- endif -%}

                {%- else -%}
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="7"/><path d="M12 8v4l3 3"/></svg>

              {%- endcase -%}
            </div>
            {%- if block.settings.label != blank -%}
              <span class="cp-label-{{ section.id }}">{{ block.settings.label }}</span>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.show_badge and section.settings.badge_text != blank -%}
      <div>
        <span class="cp-badge-{{ section.id }}">
          <span class="cp-badge-dot-{{ section.id }}"></span>
          {{ section.settings.badge_text }}
        </span>
      </div>
    {%- endif -%}

  </div>
</section>

<script>
  (function () {
    var section = document.getElementById('Compat-{{ section.id }}');
    if (!section) return;
    var els = section.querySelectorAll('.cp-reveal-{{ section.id }}');
    if ('IntersectionObserver' in window) {
      var obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            obs.unobserve(e.target);
          }
        });
      }, { threshold: 0.12 });
      els.forEach(function (el) { obs.observe(el); });
    } else {
      els.forEach(function (el) { el.classList.add('visible'); });
    }
  })();
</script>

{% schema %}
{
  "name": "Cooktop Compatibility",
  "tag": "section",
  "class": "section-compat",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Works on Every Cooktop"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "All Relica cookware is engineered for universal compatibility"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show accent divider line",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show badge strip below icons",
      "default": false
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "ISI Certified · PFOA Free · Universal Compatible"
    },
    {
      "type": "range",
      "id": "header_spacing",
      "label": "Space below subtitle",
      "min": 12,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },

    {
      "type": "header",
      "content": "Circle Style"
    },
    {
      "type": "range",
      "id": "circle_size",
      "label": "Circle size",
      "min": 40,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 52
    },
    {
      "type": "range",
      "id": "circle_radius",
      "label": "Circle corner radius",
      "info": "0 = square corners, 50 = rounded, 100 = full circle",
      "min": 0,
      "max": 100,
      "step": 10,
      "default": 100
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 12,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "icon_gap",
      "label": "Gap between icons",
      "min": 12,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 44
    },
    {
      "type": "range",
      "id": "label_gap",
      "label": "Gap between circle and label",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label font size",
      "min": 9,
      "max": 15,
      "step": 1,
      "unit": "px",
      "default": 11
    },

    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size_min",
      "label": "Title min size (mobile)",
      "min": 20,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 26
    },
    {
      "type": "range",
      "id": "title_size_max",
      "label": "Title max size (desktop)",
      "min": 28,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 34
    },

    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#1C3557"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "title_italic_color",
      "label": "Title italic accent color",
      "default": "#D9A49E"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle color",
      "default": "#627A93"
    },
    {
      "type": "color",
      "id": "circle_border_color",
      "label": "Circle border color",
      "default": "#2E4F6E"
    },
    {
      "type": "color",
      "id": "circle_bg_color",
      "label": "Circle background color",
      "default": "#00000000"
    },
    {
      "type": "color",
      "id": "circle_hover_border",
      "label": "Circle border color (hover)",
      "default": "#7A9AB5"
    },
    {
      "type": "color",
      "id": "circle_hover_bg",
      "label": "Circle background color (hover)",
      "default": "#1D3F5F"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon stroke color",
      "default": "#8AAABF"
    },
    {
      "type": "color",
      "id": "icon_hover_color",
      "label": "Icon stroke color (hover)",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#627A93"
    },
    {
      "type": "color",
      "id": "label_hover_color",
      "label": "Label color (hover)",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider / badge dot color",
      "default": "#C4827A"
    },

    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max content width",
      "min": 600,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "default": 800
    },
    {
      "type": "range",
      "id": "side_padding",
      "label": "Side padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],

  "blocks": [
    {
      "type": "icon",
      "name": "Compatibility Icon",
      "limit": 12,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "gas",        "label": "Gas"        },
            { "value": "induction",  "label": "Induction"  },
            { "value": "electric",   "label": "Electric"   },
            { "value": "ceramic",    "label": "Ceramic"    },
            { "value": "halogen",    "label": "Halogen"    },
            { "value": "dishwasher", "label": "Dishwasher" },
            { "value": "oven",       "label": "Oven"       },
            { "value": "microwave",  "label": "Microwave"  },
            { "value": "bbq",        "label": "BBQ / Grill"},
            { "value": "custom",     "label": "Custom SVG" }
          ],
          "default": "gas"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Gas"
        },
        {
          "type": "html",
          "id": "custom_svg",
          "label": "Custom SVG code",
          "info": "Only used when Icon is set to 'Custom SVG'. Paste a full <svg> tag."
        }
      ]
    }
  ],

  "max_blocks": 12,

  "presets": [
    {
      "name": "Cooktop Compatibility",
      "blocks": [
        { "type": "icon", "settings": { "icon": "gas",        "label": "Gas"        } },
        { "type": "icon", "settings": { "icon": "induction",  "label": "Induction"  } },
        { "type": "icon", "settings": { "icon": "electric",   "label": "Electric"   } },
        { "type": "icon", "settings": { "icon": "ceramic",    "label": "Ceramic"    } },
        { "type": "icon", "settings": { "icon": "halogen",    "label": "Halogen"    } },
        { "type": "icon", "settings": { "icon": "dishwasher", "label": "Dishwasher" } }
      ]
    }
  ]
}
{% endschema %}
